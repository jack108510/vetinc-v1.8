<script>
function parseMoney(v){
  if(!v) return 0; const n=parseFloat(String(v).replace(/[^0-9.\-]/g,'')); return isNaN(n)?0:n;
}
function toggleImplRow(el){
  const row=el.closest('.impl-row');
  if(!row) return;
  row.classList.toggle('excluded');
  const isExcluded=row.classList.contains('excluded');
  el.textContent=isExcluded?'Undo':'Remove';
  el.className='remove-btn'+(isExcluded?' undo':'');
  updateImplementTotal();
}
function updateImplementTotal(){
  const totalEl=document.getElementById('implementTotal');
  const items=document.querySelectorAll('#implementList .impl-row');
  let total=0;
  items.forEach(i=>{
    if(!i.classList.contains('excluded')) total+=parseMoney(i.getAttribute('data-uplift'));
  });
  if(totalEl) totalEl.textContent = total ? ('$'+total.toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})) : '$0';
}
function applyChanges(){
  const kept=document.querySelectorAll('#implementList .impl-row:not(.excluded)');
  const removed=document.querySelectorAll('#implementList .impl-row.excluded');
  alert('Applying '+kept.length+' price changes. '+removed.length+' items excluded.');
  closeImplement();
}
function openCampaignImplement(type){
  const list = document.getElementById('implementList');
  const title = document.getElementById('implementTitle');
  if(!list||!title) return;
  title.textContent = 'Implement ' + (type==='inflation'?'Inflation Adjustment':type==='99-pricing'?'.99 Pricing':'Micro‑Margin') + ' Campaign';
  const tableId = type==='inflation'?'c1Table':type==='99-pricing'?'c2Table':type==='shoppables'?'c4Table':'c3Table';
  const table = document.getElementById(tableId);
  let rows = table ? Array.from(table.querySelectorAll('tr')) : [];
  if (!rows.length) {
    list.innerHTML = '<div class="modal-item"><span>No price changes found.</span></div>';
  } else {
    list.innerHTML = rows.map((r,idx)=>{
      const tds = Array.from(r.querySelectorAll('td')).map(td=>td.textContent.trim());
      if (type==='inflation') {
        const name = tds[1] || tds[0];
        const current = tds[5] || '';
        const suggested = tds[6] || '';
        const usage = tds[8] || '0';
        const uplift = tds[9] || '0';
        return `<div class="impl-row" data-uplift="${uplift}"><div style="flex:1;min-width:160px"><b>${name}</b></div><span style="font-size:.82rem">${current} → <b>${suggested}</b></span><span class="impl-usage">${usage}/yr</span><span style="font-size:.82rem;font-weight:700;color:var(--green)">${uplift}/yr</span><button class="remove-btn" onclick="toggleImplRow(this)">Remove</button></div>`;
      }
      if (type==='99-pricing') {
        const name = tds[0] || '';
        const current = tds[2] || '';
        const suggested = tds[3] || '';
        const usage = tds[5] || '0';
        const uplift = tds[6] || '0';
        return `<div class="impl-row" data-uplift="${uplift}"><div style="flex:1;min-width:160px"><b>${name}</b></div><span style="font-size:.82rem">${current} → <b>${suggested}</b></span><span class="impl-usage">${usage}/yr</span><span style="font-size:.82rem;font-weight:700;color:var(--green)">${uplift}/yr</span><button class="remove-btn" onclick="toggleImplRow(this)">Remove</button></div>`;
      }
      const name = tds[0] || '';
      const current = (tds[1]||'').replace(/\s+/g,' ');
      const suggested = (tds[2]||'').replace(/\s+/g,' ');
      const usage = tds[3] || '0';
      const uplift = tds[4] || '0';
      return `<div class="impl-row" data-uplift="${uplift}"><div style="flex:1;min-width:160px"><b>${name}</b></div><span style="font-size:.82rem">${current} → <b>${suggested}</b></span><span class="impl-usage">${usage}/yr</span><span style="font-size:.82rem;font-weight:700;color:var(--green)">${uplift}/yr</span><button class="remove-btn" onclick="toggleImplRow(this)">Remove</button></div>`;
    }).join('');
  }
  updateImplementTotal();
  document.getElementById('implementModal').style.display='flex';
}
function generateReport(type){
  const tableId = type==='inflation'?'c1Table':type==='99-pricing'?'c2Table':type==='shoppables'?'c4Table':'c3Table';
  const table = document.getElementById(tableId);
  if(!table) return alert('No data yet');
  const rows = Array.from(table.querySelectorAll('tr'));
  if(!rows.length) return alert('No data yet');

  const title = type==='inflation'?'Inflation Price Adjustment Report':type==='99-pricing'?'.99 Pricing Revenue Recovery':'Inventory Micro Margin Report';
  const heads = type==='inflation'
    ? ['Code','Description','Last Changed','Days Stale','Infl.','Current','Suggested','Delta','Usage/yr','Uplift/yr']
    : type==='99-pricing'
    ? ['Service','Category','Current Price','.99 Price','Gain/Txn','Annual Volume','Annual Uplift']
    : ['Item','Price Increase','Current → +5% Bump','Annual Volume','Extra Margin/yr'];

  let totalUplift = 0;
  let totalVolume = 0;
  const uplifts = [];
  const thCols = heads.length;
  let bodyRows = '';
  rows.forEach(r => {
    const tds = Array.from(r.querySelectorAll('td')).map(td => td.textContent.trim());
    if(!tds.length) return;
    const upliftVal = parseFloat((tds[tds.length-1]||'').replace(/[^0-9.\-]/g,''));
    if(!isNaN(upliftVal)) { totalUplift += upliftVal; uplifts.push(upliftVal); }
    if(type==='99-pricing' && tds[5]) { const v=parseFloat(tds[5].replace(/[^0-9.\-]/g,'')); if(!isNaN(v)) totalVolume+=v; }
    bodyRows += '<tr>' + tds.map((td,i) => {
      const s = i===tds.length-1 ? ' style="color:#16a34a;font-weight:700"' : '';
      return `<td${s}>${td}</td>`;
    }).join('') + '</tr>';
  });

  const thRow = '<tr>' + heads.map(h => `<th>${h}</th>`).join('') + '</tr>';
  const date = new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
  const avgUplift = uplifts.length ? totalUplift/uplifts.length : 0;

  let summaryCards = `
<div class="stat"><div class="label">Total Items</div><div class="value">${rows.length}</div></div>
<div class="stat"><div class="label">Total Annual Uplift</div><div class="value">$${totalUplift.toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</div></div>`;

  if(type==='99-pricing'){
    const gains = rows.map(r => { const tds=Array.from(r.querySelectorAll('td')); return parseFloat((tds[4]?.textContent||'').replace(/[^0-9.\-]/g,'')); }).filter(v=>!isNaN(v));
    const avgGain = gains.length ? (gains.reduce((a,b)=>a+b,0)/gains.length) : 0;
    summaryCards += `
<div class="stat"><div class="label">Avg Increase/Txn</div><div class="value">$${avgGain.toFixed(2)}</div></div>
<div class="stat"><div class="label">Total Transactions</div><div class="value">${totalVolume.toLocaleString()}</div></div>
<div class="stat"><div class="label">Avg Uplift/Item</div><div class="value">$${avgUplift.toFixed(0)}</div></div>`;
  }

  const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><style>
body{font-family:Inter,system-ui,Arial;margin:30px;color:#1e293b;font-size:12px}
h1{font-size:1.3rem;margin-bottom:4px}
.sub{color:#64748b;font-size:.82rem;margin-bottom:16px}
.summary{display:flex;gap:16px;margin-bottom:16px}
.stat{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:12px 18px}
.stat .label{font-size:.65rem;color:#64748b;text-transform:uppercase;letter-spacing:.1em;font-weight:700}
.stat .value{font-size:1.2rem;font-weight:900;color:#16a34a;margin-top:3px}
table{width:100%;border-collapse:collapse;font-size:.72rem}
th{text-align:left;background:#f8fafc;padding:6px;border-bottom:2px solid #e2e8f0;font-size:.62rem;text-transform:uppercase;color:#64748b;letter-spacing:.08em}
td{padding:5px 6px;border-bottom:1px solid #f1f5f9}
tr:nth-child(even){background:#fafbfc}
@page{size:A4;margin:15mm}
</style></head><body>
<h1>${title}</h1>
<div class="sub">Rosslyn Veterinary Clinic | Generated ${date} | Vet INC</div>
<div class="summary">
${summaryCards}
</div>
<table><thead>${thRow}</thead><tbody>${bodyRows}</tbody></table>
<div style="margin-top:16px;font-size:.7rem;color:#94a3b8">Vet INC | Powered by Wilde Automations</div>
</body></html>`;

  const win = window.open('','_blank');
  win.document.write(html);
  win.document.close();
  setTimeout(() => { win.print(); }, 500);
}
function closeImplement(){
  const m=document.getElementById('implementModal');
  if(m) m.style.display='none';
}
</script><script src="js/insightsEngine.js"></script><script src="js/healthWidget.js"></script><script>
// Hook insights loading into tab switches
(function(){
  var _origShowTab = window.showTab;
  window.showTab = function(name, btn) {
    _origShowTab(name, btn);
    if (name === 'insights') InsightsEngine.load();
  };
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() { InsightsEngine.load(); }, 2000);
  });
})();
</script>
</body></html>
