 --><section id="tab-ai" class="section"><div style="min-height:60vh;display:flex;align-items:center;justify-content:center;background:#eff6ff"><div style="background:#fff;border-radius:16px;box-shadow:0 2px 16px rgba(37,99,235,0.08);padding:3rem 4rem;text-align:center;max-width:480px"><div style="font-size:3.5rem;margin-bottom:1rem">&#129302;</div><div style="font-size:1.5rem;font-weight:700;color:#1e293b;margin-bottom:0.5rem">AI Assistant</div><div style="font-size:1rem;color:#94a3b8">This module is coming soon.</div></div></div></section><!-- SECTION 4: Settings
--><section id="tab-marketing" class="section">
  <div class="section-header"><div class="section-title">Marketing Intelligence</div><div class="section-sub">Campaign controls & approvals</div></div>
  <div class="campaign-grid" style="grid-template-columns:1fr;">
    <div class="campaign-card">
      <div class="campaign-title">Campaign 1 — Facebook Posts</div>
      <div class="campaign-meta">Approve / Reject content</div>
      <div class="queue">
        <div class="queue-item"><span>“Why your website matters”</span><div class="queue-actions"><button class="approve">Approve</button><button class="reject">Reject</button></div></div>
        <div class="queue-item"><span>“$29/mo local sites”</span><div class="queue-actions"><button class="approve">Approve</button><button class="reject">Reject</button></div></div>
      </div>
