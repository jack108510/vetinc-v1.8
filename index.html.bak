<!-- Exam Drop Slider -->
<div id="c4Slider" style="padding:0.75rem 1.75rem;border-bottom:1px solid var(--border)">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
    <div style="font-size:0.78rem;font-weight:700;color:var(--text)">Exam Price Drop</div>
    <div style="display:flex;align-items:center;gap:8px">
      <span style="font-size:1.1rem;font-weight:900;color:var(--primary)" id="c4DropAmount">$0</span>
      <span style="font-size:0.68rem;color:var(--muted)">per exam</span>
    </div>
  </div>
  <input type="range" id="c4DropSlider" min="0" max="50" value="0" step="1" style="width:100%;accent-color:var(--primary)">
  <div style="display:flex;justify-content:space-between;font-size:0.65rem;color:var(--muted);margin-top:2px">
    <span>No drop</span>
    <span>$50 drop</span>
  </div>
  <div style="display:flex;align-items:center;justify-content:space-between;margin-top:8px">
    <div style="display:flex;align-items:center;gap:6px">
      <span style="font-size:0.72rem;font-weight:600;color:var(--muted)">Risk Level:</span>
      <span id="c4RiskBadge" style="font-size:0.72rem;font-weight:700;padding:2px 8px;border-radius:4px;background:#dcfce7;color:#16a34a">None</span>
    </div>
    <div style="display:flex;align-items:center;gap:6px">
      <span style="font-size:0.72rem;font-weight:600;color:var(--muted)">Pairings need +</span>
      <span id="c4RequiredBump" style="font-size:0.85rem;font-weight:800;color:var(--primary)">0%</span>
      <span style="font-size:0.68rem;color:var(--muted)">to break even</span>
    </div>
  </div>
  <div style="margin-top:6px;height:6px;background:#e2e8f0;border-radius:3px;overflow:hidden">
    <div id="c4RiskBar" style="height:100%;width:0%;border-radius:3px;transition:width 0.3s,background 0.3s;background:#16a34a"></div>
  </div>
  <div style="margin-top:10px;text-align:center">
    <button id="c4PlanBtn" onclick="showC4Plan()" style="display:none;border:none;background:var(--primary);color:#fff;font-size:0.82rem;font-weight:700;padding:8px 20px;border-radius:10px;cursor:pointer;transition:transform 0.2s">See the Plan</button>
  </div>
</div>

<!-- Plan Popup Modal -->
<div id="c4PlanModal" onclick="if(event.target===this)this.style.display='none'" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;overflow-y:auto">
  <div style="max-width:700px;margin:40px auto;background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,0.3);overflow:hidden">
    <div style="padding:1.25rem 1.75rem;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
      <div style="font-size:1rem;font-weight:800;color:var(--text)">The Plan — How We Break Even</div>
      <button onclick="document.getElementById('c4PlanModal').style.display='none'" style="background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--muted)">✕</button>
    </div>
    <div id="c4PlanContent" style="padding:1.25rem 1.75rem"></div>
  </div>
</div>

<div id="c4Summary" style="display:flex;gap:2rem;padding:1rem 1.75rem;border-bottom:1px solid var(--border);background:#f8faff;flex-wrap:wrap"></div><button class="campaign-toggle" onclick="toggleCampaign(this)">See More <span class="toggle-arrow">&#9662;</span></button>
<div class="campaign-body" style="display:none"><div style="padding:0.6rem 1.75rem;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap"><span style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-right:0.5rem">Filter:</span><button class="c1-filter active" onclick="c4Filter(this,'all')">All</button><button class="c1-filter" onclick="c4Filter(this,'drops')">Exam Drops</button><button class="c1-filter" onclick="c4Filter(this,'bumps')">Pairing Bumps</button></div><div class="table-scroll"><table><thead><tr><th>Code</th><th>Description</th><th class="num">Type</th><th class="num">Current</th><th class="num">New</th><th class="num">Delta</th><th class="num">Vol / yr</th><th class="num">Impact / yr</th></tr></thead><tbody id="c4Table"></tbody></table></div></div></div></div></section><!--
 SECTION 3: Inventory Intelligence (Coming Soon)
 --><section id="tab-inventory" class="section"><div style="min-height:60vh;display:flex;align-items:center;justify-content:center;background:#eff6ff"><div style="background:#fff;border-radius:16px;box-shadow:0 2px 16px rgba(37,99,235,0.08);padding:3rem 4rem;text-align:center;max-width:520px"><div style="font-size:3rem;margin-bottom:1rem">🔒</div><div style="font-size:1.4rem;font-weight:700;color:#1e293b;margin-bottom:0.5rem">Inventory Intelligence Locked</div><div style="font-size:0.95rem;color:#94a3b8">Temporarily locked while we audit COGS and revenue data.</div></div></div></section><!--
