<div style="display:none"></div><!--
 SECTION 1: Analytics & KPIs  Widget Board
 --><section id="tab-analytics" class="section active"><style>
.uplift-board{padding:2rem;max-width:1100px;margin:0 auto}
.uplift-header{margin-bottom:1.75rem}
.uplift-title{font-size:1.2rem;font-weight:700;color:var(--text)}
.uplift-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:1.25rem}
@media(max-width:1100px){.uplift-cards{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){.uplift-cards{grid-template-columns:1fr}}
.uplift-card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:2rem 1.75rem;display:flex;flex-direction:column;gap:0.4rem;box-shadow:0 1px 6px rgba(37,99,235,.05)}
.uplift-card-label{font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted)}
.uplift-card-value{font-size:2.9rem;font-weight:800;line-height:1.05;letter-spacing:-.02em}
.uplift-card-value.ub-green{color:var(--green)}
.uplift-card-value.ub-blue{color:var(--primary)}
.uplift-card-sub{font-size:0.8rem;color:var(--muted);margin-top:.2rem}
.uplift-chart-card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:1.75rem;box-shadow:0 1px 6px rgba(37,99,235,.05);max-height:280px;overflow:hidden}
.uplift-chart-header{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem}
.uplift-chart-title{font-size:1rem;font-weight:700;color:var(--text)}
.uplift-chart-sub{font-size:0.8rem;color:var(--muted);margin-top:.25rem}
.uplift-chart-stats{display:flex;gap:1.5rem}
.uplift-chart-stat{display:flex;flex-direction:column;align-items:flex-end}
.uplift-chart-stat .stat-label{font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--muted)}
.uplift-chart-stat .stat-value{font-size:1.1rem;font-weight:700;color:var(--text)}
.uplift-chart-stat .stat-value.trend-up{color:var(--green)}
.uplift-chart-stat .stat-value.trend-down{color:var(--red)}
.uplift-breakdown{background:#fff;border:1px solid var(--border);border-radius:16px;padding:1.5rem 1.75rem;box-shadow:0 1px 6px rgba(37,99,235,.05)}
.uplift-breakdown-title{font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:1rem}
.uplift-breakdown-items{display:flex;flex-direction:column;gap:.6rem}
.uplift-breakdown-item{display:flex;justify-content:space-between;align-items:center;padding:.75rem 1rem;background:var(--bg);border-radius:8px}
.uplift-breakdown-label{font-size:.88rem;color:var(--text);font-weight:500}
.uplift-breakdown-value{font-size:.95rem;font-weight:700;color:var(--green)}

