  <span style="display:flex;align-items:center;gap:0.35rem;font-size:0.73rem;color:var(--muted)"><span style="width:10px;height:10px;border-radius:2px;background:#fef9c3;border:1px solid #ca8a04;display:inline-block"></span>Net 30-50%</span>
  <span style="display:flex;align-items:center;gap:0.35rem;font-size:0.73rem;color:var(--muted)"><span style="width:10px;height:10px;border-radius:2px;background:#fee2e2;border:1px solid #ef4444;display:inline-block"></span>Net &lt;30%</span>
  <span style="display:flex;align-items:center;gap:0.35rem;font-size:0.73rem;color:var(--muted)"><span style="width:10px;height:10px;border-radius:2px;background:#fef9c3;border:1px solid #ca8a04;display:inline-block"></span>70-85%</span>
  <span style="display:flex;align-items:center;gap:0.35rem;font-size:0.73rem;color:var(--muted)"><span style="width:10px;height:10px;border-radius:2px;background:#fee2e2;border:1px solid #ef4444;display:inline-block"></span>&lt;70%</span>
  <span style="display:flex;align-items:center;gap:0.35rem;font-size:0.73rem;color:var(--muted)"><span style="width:10px;height:10px;border-radius:2px;background:#f1f5f9;border:1px solid #cbd5e1;display:inline-block"></span>Closed</span>
</div>
<div id="calGrid" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden">
  <div style="display:grid;grid-template-columns:repeat(7,1fr);border-bottom:1px solid var(--border)">
    <div style="padding:0.5rem;text-align:center;font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em">Sun</div>
    <div style="padding:0.5rem;text-align:center;font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em">Mon</div>
    <div style="padding:0.5rem;text-align:center;font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em">Tue</div>
