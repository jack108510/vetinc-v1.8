      const sevenDaysLater = new Date(); sevenDaysLater.setDate(sevenDaysLater.getDate()+7);
      const rows = await wbGet('upcoming-appointments', { from: todayISO(), to: sevenDaysLater.toISOString().slice(0,10) });
      if (!rows || rows.length === 0) throw new Error('empty');
      const byDay = {};
      for (const r of rows) { if (r.appt_date) { byDay[r.appt_date] = (byDay[r.appt_date]||0)+1; } }
      const sorted = Object.keys(byDay).sort();
      labels = sorted.map(d => { const dt = new Date(d+'T12:00:00'); return ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][dt.getDay()]; });
      data = sorted.map(d => byDay[d]);
    } catch(e) {
      labels = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun']; data = [8,12,6,10,14,4,2];
    }
    makeChart(id, 'wc-upcoming-appts', {
      type: 'bar',
      data: { labels, datasets: [{ data, backgroundColor: 'rgba(37,99,235,0.7)', borderRadius: 4 }] },
