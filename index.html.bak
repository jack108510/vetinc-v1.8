      const rows = await wbGet('patients-per-doctor', { date: todayISO() });
      if (!rows || rows.length === 0) throw new Error('empty');
      const byDoc = {};
      for (const r of rows) { const d = r.doctor||'Unknown'; byDoc[d] = (byDoc[d]||0)+1; }
      const sorted = Object.entries(byDoc).sort((a,b)=>b[1]-a[1]);
      labels = sorted.map(([k])=>k); data = sorted.map(([,v])=>v);
    } catch(e) {
      // Stub from CSV if available
      labels = ['Dr. Smith','Dr. Jones','Dr. Lee']; data = [4,3,2];
