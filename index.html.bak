        scales: { x: { grid: { color: 'rgba(219,234,254,0.8)' }, ticks: { callback: v => '$'+(v>=1000?(v/1000).toFixed(0)+'k':v) } }, y: { grid: { display: false } } }
      }
    });
  }

  async function renderRevenueByCategory(id, bodyEl) {
    bodyEl.innerHTML = '<div class="w-chart"><canvas id="wc-rev-category"></canvas></div>';
    const CAT_NAMES = { AS:'Professional', AI:'Inventory', AM:'Medication', AT:'Other' };
    let labels = [], data = [];
    try {
      const rows = await wbGet('revenue-by-category', { month_start: monthStartISO(), month_end: nextMonthStartISO() });
      if (!rows || rows.length === 0) throw new Error('empty');
      const byCat = {};
      for (const r of rows) {
        const t = (r.category || 'other').toLowerCase();
        const name = t.charAt(0).toUpperCase() + t.slice(1);
        byCat[name] = (byCat[name]||0)+(parseFloat(r.amount)||0);
      }
      const sorted = Object.entries(byCat).sort((a,b)=>b[1]-a[1]);
      labels = sorted.map(([k])=>k); data = sorted.map(([,v])=>v);
    } catch(e) {
      const byCat = {};
      for (const [code, info] of Object.entries(AI_byCat)) {
        const name = CAT_NAMES[code] || code;
        byCat[name] = (byCat[name]||0) + info.rev;
      }
      const sorted = Object.entries(byCat).sort((a,b)=>b[1]-a[1]);
      labels = sorted.map(([k])=>k); data = sorted.map(([,v])=>v);
    }
    const palette = ['#2563eb','#7c3aed','#059669','#ea580c','#0ea5e9','#f472b6'];
    makeChart(id, 'wc-rev-category', {
      type: 'doughnut',
      data: { labels, datasets: [{ data, backgroundColor: palette, borderWidth: 2, borderColor: '#fff' }] },
      options: {
        responsive: true, maintainAspectRatio: false, cutout: '58%',
        plugins: {
          legend: { position: 'right', labels: { boxWidth: 12, padding: 8, font: { size: 10 } } },
          tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${fmt$(ctx.raw)}` } }
        }
      }
    });
  }

