      }
    });
  }

  async function renderPriceStaleness(id, bodyEl) {
    let items = [];
    try {
      const result = await wbGet('price-staleness', {});
      const priceRows = result.prices || [];
      const treatRows = result.treatments || [];
      const svcRows = result.services || [];
      if (!priceRows || priceRows.length === 0) throw new Error('empty');

      const treatNames = {};
      for (const t of (treatRows||[])) { if (t.code) treatNames[t.code] = (itemNamesMap && itemNamesMap[t.code]) || t.name || t.code; }

      const usageMap = {};
      for (const r of (svcRows||[])) {
        const code = (r.code||'').trim();
        const qty = parseFloat(r.quantity)||0;
        if (code && qty > 0) usageMap[code] = (usageMap[code]||0)+qty;
      }

      const priceMap = {};
      for (const row of priceRows) {
        const code = (row.treatment_code||'').trim();
        const price = parseFloat(row.price)||0;
        const d = row.updated_at ? new Date(row.updated_at) : null;
        if (!code || !d || price <= 0) continue;
        if (!priceMap[code] || d > priceMap[code].lastMod) {
          priceMap[code] = { lastMod: d, price, name: treatNames[code]||code };
        }
      }

      const TODAY = new Date();
      const ONE_YR_AGO = new Date(TODAY); ONE_YR_AGO.setFullYear(TODAY.getFullYear()-1);
      for (const [code, info] of Object.entries(priceMap)) {
        if (info.lastMod >= ONE_YR_AGO) continue;
        if (!usageMap[code] || usageMap[code] <= 0) continue;
        const fromYear = info.lastMod.getFullYear();
        const factor = compoundInflation(fromYear, 2025);
        const suggested = parseFloat((info.price * factor).toFixed(2));
        const delta = parseFloat((suggested - info.price).toFixed(2));
        if (delta <= 0.005) continue;
        const inflPct = ((factor - 1) * 100).toFixed(1);
        const usage = usageMap[code];
        const uplift = parseFloat((delta * usage).toFixed(2));
        const gapPct = info.price > 0 ? delta / info.price : 0;
        items.push({ id: code, name: info.name, lastModStr: info.lastMod.toLocaleDateString('en-CA'), inflPct, gapPct, uplift });
      }
      items.sort((a,b) => b.uplift - a.uplift);
    } catch(e) {
      items = (c1AllItems||[]).slice(0,10);
    }

    items = items.slice(0,10);
    if (!items.length) {
      bodyEl.innerHTML = '<div class="w-sub">Price history data not loaded yet.</div>';
      return;
    }
    const totalUplift = items.reduce((s,i) => s+i.uplift, 0);
    const rows = items.map(it => {
      const gapColor = it.gapPct > 0.15 ? '#ef4444' : it.gapPct > 0.07 ? '#ea580c' : '#64748b';
      return `<tr><td style="font-size:0.76rem;padding:4px 6px">${escHtml(it.name||it.id)}</td>
        <td style="text-align:right;font-size:0.76rem;padding:4px 6px;color:#64748b">${it.lastModStr}</td>
        <td style="text-align:right;font-size:0.76rem;padding:4px 6px;color:${gapColor};font-weight:700">+${it.inflPct}%</td>
        <td style="text-align:right;font-size:0.76rem;padding:4px 6px;color:#16a34a;font-weight:700">+${fmt$(it.uplift)}</td></tr>`;
    }).join('');
    bodyEl.innerHTML = `
      <div style="display:flex;gap:1.5rem;margin-bottom:10px;flex-wrap:wrap">
        <div><div class="kpi-label">Est. Annual Uplift</div><div style="font-size:1.2rem;font-weight:900;color:var(--green)">${fmt$(totalUplift)}</div></div>
        <div><div class="kpi-label">Items Behind</div><div style="font-size:1.2rem;font-weight:900">${items.length}+</div></div>
      </div>
      <div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:0.76rem">
        <thead><tr>
          <th style="text-align:left;font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#64748b;padding:4px 6px;border-bottom:1px solid var(--border)">Item</th>
          <th style="text-align:right;font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#64748b;padding:4px 6px;border-bottom:1px solid var(--border)">Last Changed</th>
          <th style="text-align:right;font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#64748b;padding:4px 6px;border-bottom:1px solid var(--border)">Infl. %</th>
          <th style="text-align:right;font-size:0.65rem;font-weight:700;text-transform:uppercase;color:#64748b;padding:4px 6px;border-bottom:1px solid var(--border)">Uplift/yr</th>
        </tr></thead><tbody>${rows}</tbody>
      </table></div>`;
  }

  async function renderInventoryProjection(id, bodyEl) {
    // Inventory spend from services where service_type = 'AI' or 'AM'
    // Weighted: 40% last 3mo, 30% last 6mo, 20% same month historical, 10% 12mo avg
    let projection = 0;
    try {
      const twelveMonthsAgo = (() => { const d = new Date(); d.setFullYear(d.getFullYear()-1); return d.toISOString().slice(0,10); })();
      const rows = await wbGet('inventory-projection', { from: twelveMonthsAgo });
      if (!rows || rows.length === 0) throw new Error('empty');
      const now = new Date();
      const threeMonthsAgo = new Date(now); threeMonthsAgo.setMonth(now.getMonth()-3);
      const sixMonthsAgo = new Date(now); sixMonthsAgo.setMonth(now.getMonth()-6);
      let rev3=0,cnt3=0,rev6=0,cnt6=0,rev12=0,cnt12=0,sameMo=0,sameCnt=0;
      for (const r of rows) {
        if (!r.created_at) continue;
        const d = new Date(r.created_at);
        const amt = parseFloat(r.amount)||0;
        const mo = d.getMonth();
        rev12 += amt; cnt12++;
        if (d >= sixMonthsAgo) { rev6 += amt; cnt6++; }
        if (d >= threeMonthsAgo) { rev3 += amt; cnt3++; }
        if (mo === now.getMonth()) { sameMo += amt; sameCnt++; }
      }
      const avg3 = cnt3>0 ? rev3/3 : 0;
      const avg6 = cnt6>0 ? rev6/6 : 0;
      const avg12 = cnt12>0 ? rev12/12 : 0;
      const avgSame = sameCnt>0 ? sameMo/Math.max(1, (now.getFullYear()-new Date(rows[0].created_at).getFullYear())) : avg12;
      projection = avg3*0.4 + avg6*0.3 + avgSame*0.2 + avg12*0.1;
    } catch(e) {
      // Fallback: estimate 30% of total revenue as inventory
      const k = AI_monthKeys[AI_monthKeys.length-1]||'';
      projection = AI_byMonth[k] ? AI_byMonth[k].rev * 0.28 : 0;
    }
    bodyEl.innerHTML = `<div class="w-value">${fmt$(projection)}</div><div class="w-sub">projected inventory spend next month</div><div class="w-sub" style="margin-top:6px;font-size:0.68rem">40% last 3mo avg  30% last 6mo  20% same month  10% 12mo avg</div>`;
  }

  async function renderYTDRevenue(id, bodyEl) {
    let total = 0;
    try {
      const rows = await wbGet('ytd-revenue', {});
      total = sumAmount(rows);
    } catch(e) {
      // Fallback: sum all months in current year from AI data
      const yr = String(new Date().getFullYear());
      for (const [k, v] of Object.entries(AI_byMonth)) {
        if (k.startsWith(yr)) total += v.rev;
      }
    }
    const yr = new Date().getFullYear();
    bodyEl.innerHTML = `<div class="w-value">${fmt$(total)}</div><div class="w-sub">${yr} Year-to-Date</div>`;
  }

  //  Skeleton loading 
  function showSkeleton(bodyEl, size) {
    if (size === 'small') {
      bodyEl.innerHTML = '<div class="widget-skeleton"><div class="shimmer sk-value"></div><div class="shimmer sk-line" style="width:70%"></div></div>';
    } else {
      bodyEl.innerHTML = '<div class="widget-skeleton"><div class="shimmer sk-line" style="width:40%"></div><div class="shimmer sk-chart"></div></div>';
    }
  }

  //  Widget card builder 
  function buildCard(id) {
    const def = CATALOG.find(c => c.id === id);
    if (!def) return null;
    const card = document.createElement('div');
    card.className = 'widget-card';
    card.dataset.id = id;
    card.dataset.size = def.size;
    card.draggable = true;
    card.innerHTML = `
      <button class="widget-ios-remove" data-wid="${id}" title="Remove">&#8722;</button>
      <div class="widget-header">
        <span class="widget-drag-handle" title="Drag to reorder">&#9776;</span>
        <span class="widget-title">${def.title}</span>
        <div class="widget-actions">
          <button class="widget-btn wbtn-refresh" title="Refresh" data-wid="${id}">&#8635;</button>
        </div>
      </div>
      <div class="widget-body" id="wb-${id}"></div>
      <div class="widget-footer" id="wf-${id}">Loading</div>
    `;
    // Drag events
    card.addEventListener('dragstart', e => {
      dragSrcId = id;
      card.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    card.addEventListener('dragend', () => card.classList.remove('dragging'));
    card.addEventListener('dragover', e => { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; card.classList.add('drag-over'); });
    card.addEventListener('dragleave', () => card.classList.remove('drag-over'));
    card.addEventListener('drop', e => {
      e.preventDefault();
      card.classList.remove('drag-over');
      if (dragSrcId && dragSrcId !== id) {
        const srcIdx = layout.indexOf(dragSrcId);
        const dstIdx = layout.indexOf(id);
        if (srcIdx !== -1 && dstIdx !== -1) {
          layout.splice(srcIdx, 1);
          layout.splice(dstIdx, 0, dragSrcId);
          saveLayout();
          renderBoard();
        }
      }
    });
    return card;
  }

  function loadCard(id) {
    const def = CATALOG.find(c => c.id === id);
    if (!def) return;
    const bodyEl = document.getElementById('wb-'+id);
    const footerEl = document.getElementById('wf-'+id);
    if (!bodyEl) return;
    showSkeleton(bodyEl, def.size);
    renderWidget(id, bodyEl, footerEl);
  }

  //  Board render 
  function renderBoard() {
    const board = document.getElementById('widgetBoard');
    if (!board) return;
    // Destroy old charts
    for (const cid of Object.keys(chartMap)) destroyChart(cid);
    board.innerHTML = '';
    layout.forEach((id, i) => {
      const card = buildCard(id);
      if (!card) return;
      board.appendChild(card);
      // Stagger entry animation
      card.classList.add('entering');
      card.style.animationDelay = (i * 50) + 'ms';
      const dur = 320 + i * 50;
      setTimeout(() => card.classList.remove('entering'), dur);
    });
    // Bind action buttons
    board.querySelectorAll('.wbtn-refresh').forEach(btn => {
      btn.addEventListener('click', () => refreshWidget(btn.dataset.wid));
    });
    board.querySelectorAll('.widget-ios-remove').forEach(btn => {
      btn.addEventListener('click', () => removeWidget(btn.dataset.wid));
    });
    // Load data for each widget
    for (const id of layout) loadCard(id);
    // Re-apply jiggle if in jiggle mode
    if (isJiggleMode) applyJiggle();
  }

  //  Layout persistence 
  function saveLayout() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(layout)); } catch(e) {}
  }

  function loadLayout() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) { const parsed = JSON.parse(saved); if (Array.isArray(parsed) && parsed.length > 0) return parsed; }
    } catch(e) {}
    return [...DEFAULT_LAYOUT];
  }

  //  Widget add/remove 
  function removeWidget(id) {
    const card = document.querySelector(`.widget-card[data-id="${id}"]`);
    if (card) {
      card.classList.add('removing');
      setTimeout(() => {
        destroyChart(id);
        layout = layout.filter(i => i !== id);
        saveLayout();
        renderBoard();
        updateCatalogUI();
      }, 230);
    } else {
      destroyChart(id);
      layout = layout.filter(i => i !== id);
      saveLayout();
      renderBoard();
      updateCatalogUI();
    }
  }

  function addWidget(id) {
    if (layout.includes(id)) return;
    layout.push(id);
    saveLayout();
    renderBoard();
    updateCatalogUI();
  }

  //  Jiggle mode 
  function applyJiggle() {
    document.querySelectorAll('#widgetBoard .widget-card').forEach(card => {
      card.classList.add('jiggling');
    });
  }

  function enterJiggleMode() {
    isJiggleMode = true;
    applyJiggle();
    const editBtn = document.getElementById('btnEditWidgets');
    if (editBtn) { editBtn.textContent = 'Done'; editBtn.classList.add('done'); }
    const addBtn = document.getElementById('btnAddWidget');
    if (addBtn) addBtn.classList.add('visible');
  }

  function exitJiggleMode() {
    isJiggleMode = false;
    document.querySelectorAll('#widgetBoard .widget-card').forEach(card => {
      card.classList.remove('jiggling');
    });
    const editBtn = document.getElementById('btnEditWidgets');
    if (editBtn) { editBtn.textContent = 'Edit'; editBtn.classList.remove('done'); }
    const addBtn = document.getElementById('btnAddWidget');
    if (addBtn) addBtn.classList.remove('visible');
  }

  function refreshWidget(id) {
    // Invalidate cache for this widget's data
    for (const k of Object.keys(sbCache)) delete sbCache[k];
    const def = CATALOG.find(c => c.id === id);
    if (!def) return;
    destroyChart(id);
    const bodyEl = document.getElementById('wb-'+id);
    const footerEl = document.getElementById('wf-'+id);
    if (!bodyEl) return;
    showSkeleton(bodyEl, def.size);
    renderWidget(id, bodyEl, footerEl);
  }

  //  Modal 
  function buildCatalogUI(filter) {
    const grid = document.getElementById('widgetCatalogGrid');
    if (!grid) return;
    const q = (filter||'').toLowerCase();
    const visible = q ? CATALOG.filter(c => c.title.toLowerCase().includes(q)) : CATALOG;
    grid.innerHTML = visible.map(c => {
      const added = layout.includes(c.id);
      return `<div class="catalog-card">
        <div class="catalog-card-name">${escHtml(c.title)}</div>
        <span class="catalog-card-size ${c.size}">${c.size}</span>
        <button class="catalog-add" ${added?'disabled':''} data-cid="${c.id}">${added ? 'Added ' : 'Add'}</button>
      </div>`;
    }).join('');
    grid.querySelectorAll('.catalog-add:not(:disabled)').forEach(btn => {
      btn.addEventListener('click', () => { addWidget(btn.dataset.cid); closeModal(); });
    });
  }

  function updateCatalogUI() { buildCatalogUI(document.getElementById('widgetSearch')?.value||''); }

  function openModal() {
    buildCatalogUI('');
    document.getElementById('widgetModalOverlay').classList.add('open');
  }

  function closeModal() {
    document.getElementById('widgetModalOverlay').classList.remove('open');
  }

  //  Init 
  function init() {
    // Force fresh layout to ensure New Clients shows
    layout = DEFAULT_LAYOUT.slice();
    saveLayout(layout);

    // Edit / Done button toggles jiggle mode
    document.getElementById('btnEditWidgets')?.addEventListener('click', () => {
      if (isJiggleMode) exitJiggleMode(); else enterJiggleMode();
    });

    // Floating Add Widget button opens modal
    document.getElementById('btnAddWidget')?.addEventListener('click', openModal);
    document.getElementById('btnModalClose')?.addEventListener('click', closeModal);
    document.getElementById('widgetModalOverlay')?.addEventListener('click', e => {
      if (e.target.id === 'widgetModalOverlay') closeModal();
    });
    document.getElementById('widgetSearch')?.addEventListener('input', e => buildCatalogUI(e.target.value));

    // Click outside cards in jiggle mode exits jiggle
    document.getElementById('tab-analytics')?.addEventListener('click', e => {
      if (!isJiggleMode) return;
      if (!e.target.closest('.widget-card') &&
          !e.target.closest('#btnEditWidgets') &&
          !e.target.closest('#btnAddWidget')) {
        exitJiggleMode();
      }
    });

    // Activate on tab switch
    const origShowTab = window.showTab;
    window.showTab = function(name, btn) {
      origShowTab(name, btn);
      if (name === 'analytics') { if (isJiggleMode) exitJiggleMode(); renderBoard(); }
    };

    // Initial render if analytics tab is active
    if (document.getElementById('tab-analytics')?.classList.contains('active')) {
      renderBoard();
    }
  }

  return {
    init,
    retryWidget: refreshWidget,
    onCSVReady() {
      csvReady = true;
      // Re-render widgets that may have fallen back to stubs
      if (document.getElementById('tab-analytics')?.classList.contains('active')) {
        renderBoard();
      }
    }
  };
})();

//
// Clinic Settings Module
//
const ClinicSettings = (() => {
  const SB_URL = 'https://rnqhhzatlxmyvccdvqkr.supabase.co';
  const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30';
  const CLINIC_ID = 'rosslyn';

  const DEFAULT_FIXED = [
    { label: 'Rent / Facility', amount: 0 },
    { label: 'Staff Salaries', amount: 0 },
    { label: 'Insurance', amount: 0 },
    { label: 'Licenses & Permits', amount: 0 },
    { label: 'Equipment Lease', amount: 0 },
    { label: 'Marketing Budget', amount: 0 },
    { label: 'Other Fixed Costs', amount: 0 },
  ];
  const DEFAULT_UTILITY = [
    { label: 'Electricity', amount: 0 },
    { label: 'Water & Sewer', amount: 0 },
    { label: 'Gas / Heat', amount: 0 },
    { label: 'Internet & Phone', amount: 0 },
    { label: 'Waste Management', amount: 0 },
    { label: 'Other Utilities', amount: 0 },
  ];

  let fixedCosts = DEFAULT_FIXED.map(r => ({ ...r }));
  let utilityCosts = DEFAULT_UTILITY.map(r => ({ ...r }));
  let saveTimer = null;
  let loadStarted = false;
  let loaded = false;

  // Global accessors for profit calculations
  window.clinicFixedCosts = () => fixedCosts;
  window.clinicUtilityCosts = () => utilityCosts;
  window.clinicTotalFixed = () => fixedCosts.reduce((s, r) => s + (parseFloat(r.amount) || 0), 0);
  window.clinicTotalUtility = () => utilityCosts.reduce((s, r) => s + (parseFloat(r.amount) || 0), 0);

  function fmtDollar(n) {
    return '$' + (parseFloat(n) || 0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function renderList(type) {
    const rows = type === 'fixed' ? fixedCosts : utilityCosts;
    const containerId = type === 'fixed' ? 'fixedCostsList' : 'utilityCostsList';
    const container = document.getElementById(containerId);
    if (!container) return;
    container.innerHTML = '';
    rows.forEach((row, idx) => {
      const div = document.createElement('div');
      div.className = 'cost-row';
      const safeLabel = String(row.label || '').replace(/"/g, '&quot;');
      div.innerHTML =
        '<input class="cost-label-input" type="text" value="' + safeLabel + '" placeholder="Label"' +
        ' onchange="ClinicSettings.updateRow(\'' + type + '\',' + idx + ',\'label\',this.value)" />' +
        '<input class="cost-amount-input" type="number" min="0" step="0.01" value="' + (row.amount || '') + '" placeholder="0.00"' +
        ' oninput="ClinicSettings.updateRow(\'' + type + '\',' + idx + ',\'amount\',this.value)" />' +
        '<button class="cost-delete-btn" onclick="ClinicSettings.deleteRow(\'' + type + '\',' + idx + ')" title="Remove">&#8722;</button>';
      container.appendChild(div);
    });
    updateTotal(type);
  }

  function updateTotal(type) {
    const rows = type === 'fixed' ? fixedCosts : utilityCosts;
    const total = rows.reduce((s, r) => s + (parseFloat(r.amount) || 0), 0);
    const elId = type === 'fixed' ? 'fixedCostsTotal' : 'utilityCostsTotal';
    const el = document.getElementById(elId);
    if (el) el.textContent = fmtDollar(total);
  }

  function scheduleSave() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveToSupabase, 1000);
  }

  async function saveToSupabase() {
    try {
      const payload = {
        clinic_id: CLINIC_ID,
        fixed_costs: fixedCosts,
        utility_costs: utilityCosts,
        updated_at: new Date().toISOString()
      };
      const res = await fetch(SB_URL + '/rest/v1/clinic_settings', {
        method: 'POST',
        headers: {
          apikey: SB_KEY,
          Authorization: 'Bearer ' + SB_KEY,
          'Content-Type': 'application/json',
          Prefer: 'resolution=merge-duplicates'
        },
        body: JSON.stringify(payload)
      });
      if (!res.ok) {
        console.warn('Settings save failed:', res.status, await res.text());
        return;
      }
      showSavedIndicator();
    } catch (e) {
      console.warn('Settings save error:', e);
    }
  }

  async function loadFromSupabase() {
    try {
      const res = await fetch(SB_URL + '/rest/v1/clinic_settings?clinic_id=eq.' + CLINIC_ID + '&limit=1', {
        headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, Accept: 'application/json' }
      });
      if (res.status === 404) {
        console.log(' clinic_settings table not found (ok for now), using defaults');
      } else if (!res.ok) {
        throw new Error('SB ' + res.status);
      } else {
        const rows = await res.json();
        if (rows.length) {
          const row = rows[0];
          if (row.fixed_costs && row.fixed_costs.length) fixedCosts = row.fixed_costs;
          if (row.utility_costs && row.utility_costs.length) utilityCosts = row.utility_costs;
        }
      }
    } catch (e) {
      console.warn('Settings load error (non-critical):', e);
    }
    loaded = true;
    renderList('fixed');
    renderList('utility');
  }

  function showSavedIndicator() {
    const el = document.getElementById('settingsSaveIndicator');
    if (!el) return;
    el.textContent = 'Saved just now';
    el.classList.add('visible');
    setTimeout(() => el.classList.remove('visible'), 3000);
  }

  function addRow(type) {
    const rows = type === 'fixed' ? fixedCosts : utilityCosts;
    rows.push({ label: '', amount: 0 });
    renderList(type);
    scheduleSave();
    const containerId = type === 'fixed' ? 'fixedCostsList' : 'utilityCostsList';
    const container = document.getElementById(containerId);
    if (container) {
      const inputs = container.querySelectorAll('.cost-label-input');
      if (inputs.length) inputs[inputs.length - 1].focus();
    }
  }

  function deleteRow(type, idx) {
    const rows = type === 'fixed' ? fixedCosts : utilityCosts;
    rows.splice(idx, 1);
    renderList(type);
    scheduleSave();
  }

  function updateRow(type, idx, field, value) {
    const rows = type === 'fixed' ? fixedCosts : utilityCosts;
    if (!rows[idx]) return;
    rows[idx][field] = field === 'amount' ? (parseFloat(value) || 0) : value;
    updateTotal(type);
    scheduleSave();
  }

  function init() {
    if (!loadStarted) {
      loadStarted = true;
      loadFromSupabase().catch(e => console.warn('Settings init error (non-critical):', e));
    } else if (loaded) {
      renderList('fixed');
      renderList('utility');
    }
  }

  return { init, addRow, deleteRow, updateRow };
})();


//
// Insights Widget Dashboard
//
const InsightsDashboard = (() => {
  let fetchStarted = false;
  let dailyRevMap = {}; // { 'YYYY-MM-DD': totalRev }
  let revLoaded = false;
  let activeDrawer = null;
  let profitFixedCosts = null; // working copy for profit drawer
  let mockRevMap = null; // generated once for mock data

  function fd(n) {
    return '$' + (n || 0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }
  function fmtDate(iso) {
    const d = new Date(iso + 'T12:00:00');
    return d.toLocaleDateString('en-CA', { month: 'short', day: 'numeric' });
  }
  function getLast30Days() {
    const days = [];
    for (let i = 29; i >= 0; i--) {
      const d = new Date(Date.now() - i * 86400000);
      days.push(d.toISOString().slice(0, 10));
    }
    return days;
  }

  function getTotalMonthly() {
    const fixed = (typeof clinicFixedCosts === 'function') ? clinicFixedCosts() : [];
    const utility = (typeof clinicUtilityCosts === 'function') ? clinicUtilityCosts() : [];
    return [...fixed, ...utility].reduce((s, r) => s + (parseFloat(r.amount) || 0), 0);
  }

  function getDefaultProfitCosts() {
    return [
      { label: 'Rent', amount: 3000 },
      { label: 'Salaries', amount: 15000 },
      { label: 'Software', amount: 500 },
      { label: 'Misc', amount: 500 }
    ];
  }

  function initProfitCosts() {
    const cs = (typeof clinicFixedCosts === 'function') ? clinicFixedCosts() : [];
    if (cs && cs.length > 0) {
      profitFixedCosts = cs.map(r => ({ label: r.label || '', amount: parseFloat(r.amount) || 0 }));
    } else {
      profitFixedCosts = getDefaultProfitCosts();
    }
  }

  function getProfitDailyCost() {
    if (!profitFixedCosts) initProfitCosts();
    return profitFixedCosts.reduce((s, r) => s + (r.amount || 0), 0) / 30;
  }

  function getMockRevMap() {
    if (mockRevMap) return mockRevMap;
    mockRevMap = {};
    const days = getLast30Days();
    // Seed with a stable pseudo-random so it doesn't change on re-render
    let seed = 42;
    function rand() { seed = (seed * 1664525 + 1013904223) & 0xffffffff; return (seed >>> 0) / 0xffffffff; }
    for (const d of days) {
      mockRevMap[d] = Math.round((800 + rand() * 3200) * 100) / 100;
    }
    return mockRevMap;
  }

  function getEffectiveRevMap() {
    return revLoaded ? dailyRevMap : getMockRevMap();
  }

  function updateWidgetCards() {
    const totalMonthly = getTotalMonthly();
    const dailyCost = totalMonthly / 30;

    // Widget 2: Cost Per Day (always available from settings)
    const e2m = document.getElementById('iw2-monthly');
    const e2d = document.getElementById('iw2-cpd');
    const e2w = document.getElementById('iw2-cpwd');
    if (e2m) e2m.textContent = fd(totalMonthly);
    if (e2d) e2d.textContent = fd(dailyCost);
    if (e2w) e2w.textContent = fd(totalMonthly / 22);

    if (!revLoaded) return;

    const days = getLast30Days();
    const revVals = days.map(d => dailyRevMap[d] || 0);
    const totalRev = revVals.reduce((s, v) => s + v, 0);
    const avgDailyRev = totalRev / 30;

    // Widget 1: Profit Calculator
    const profitDailyCost = getProfitDailyCost();
    const margin = avgDailyRev > 0 ? ((avgDailyRev - profitDailyCost) / avgDailyRev) * 100 : 0;
    let posD = 0, negD = 0;
    for (const d of days) {
      const rev = dailyRevMap[d] || 0;
      if (rev > 0 || profitDailyCost > 0) {
        if (rev - profitDailyCost >= 0) posD++; else negD++;
      }
    }
    const e1m = document.getElementById('iw1-margin');
    const e1pos = document.getElementById('iw1-pos');
    const e1neg = document.getElementById('iw1-neg');
    if (e1m) {
      e1m.textContent = margin.toFixed(1) + '%';
      e1m.style.color = margin >= 0 ? 'var(--green)' : 'var(--red)';
    }
    if (e1pos) e1pos.textContent = posD + 'd';
    if (e1neg) e1neg.textContent = negD + 'd';

    // Widget 3: Revenue Trend
    const nonZero = revVals.filter(v => v > 0);
    const best = nonZero.length ? Math.max(...nonZero) : 0;
    const worst = nonZero.length ? Math.min(...nonZero) : 0;
    const e3a = document.getElementById('iw3-avg');
    const e3b = document.getElementById('iw3-best');
    const e3w = document.getElementById('iw3-worst');
    if (e3a) e3a.textContent = fd(avgDailyRev);
    if (e3b) e3b.textContent = fd(best);
    if (e3w) e3w.textContent = fd(worst);
  }

  async function fetchRevenue() {
    try {
      const since = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
      const rows = await sbFetchAll('accounts', 'select=amount_raw,txn_date&txn_date=gte.' + since + 'T00:00:00&order=txn_date.asc');
      dailyRevMap = {};
      for (const r of rows) {
        const day = (r.txn_date || '').slice(0, 10);
        if (day) dailyRevMap[day] = (dailyRevMap[day] || 0) + ((parseFloat(r.amount_raw) || 0) / 100);
      }
      revLoaded = true;
      updateWidgetCards();
    } catch (e) {
      console.warn('InsightsDashboard revenue fetch error:', e);
    }
  }

  //  Drawer 
  function openDrawer(type) {
    activeDrawer = type;
    const backdrop = document.getElementById('iwBackdrop');
    const drawer = document.getElementById('iwDrawer');
    const title = document.getElementById('iwDrawerTitle');
    const body = document.getElementById('iwDrawerBody');
    if (!drawer || !body) return;
    if (type === 'profit') {
      title.textContent = 'Profit Calculator  Last 30 Days';
      initProfitCosts(); // reload from settings each open
      body.innerHTML = renderProfitDrawer();
      attachProfitInputListeners();
    } else if (type === 'cost') {
      title.textContent = 'Cost Per Day  Detail';
      body.innerHTML = renderCostDrawer();
      attachCostInputListeners();
    } else if (type === 'revenue') {
      title.textContent = 'Revenue Trend  Last 30 Days';
      body.innerHTML = renderRevenueDrawer();
    }
    backdrop.classList.add('open');
    drawer.classList.add('open');
  }

  function closeDrawer() {
    document.getElementById('iwBackdrop').classList.remove('open');
    document.getElementById('iwDrawer').classList.remove('open');
    activeDrawer = null;
  }

  function renderProfitDrawer() {
    if (!profitFixedCosts) initProfitCosts();
    const totalMonthly = profitFixedCosts.reduce((s, r) => s + (r.amount || 0), 0);
    const dailyCost = totalMonthly / 30;
    const days = getLast30Days();
    const revMap = getEffectiveRevMap();

    const revVals = days.map(d => revMap[d] || 0);
    const totalRev = revVals.reduce((s, v) => s + v, 0);
    const avgRev = totalRev / 30;
    const margin = avgRev > 0 ? ((avgRev - dailyCost) / avgRev) * 100 : 0;
    const marginColor = margin >= 0 ? 'var(--green)' : 'var(--red)';
    let posD = 0, negD = 0;
    for (const d of days) {
      const rev = revMap[d] || 0;
      const net = rev - dailyCost;
      if (rev > 0 || dailyCost > 0) { net >= 0 ? posD++ : negD++; }
    }

    //  3 metric pills 
    const pills =
      '<div class="iw-metric-row" style="margin-bottom:1.5rem">' +
      '<div class="iw-metric"><div class="iw-metric-label">Profit Margin</div><div class="iw-metric-value" style="color:' + marginColor + '">' + margin.toFixed(1) + '%</div></div>' +
      '<div class="iw-metric"><div class="iw-metric-label">Days Net Positive</div><div class="iw-metric-value" style="color:var(--green)">' + posD + 'd</div></div>' +
      '<div class="iw-metric"><div class="iw-metric-label">Days Net Negative</div><div class="iw-metric-value" style="color:var(--red)">' + negD + 'd</div></div>' +
      '</div>';

    //  Fixed Costs section 
    const costRows = profitFixedCosts.map((r, i) =>
      '<div class="iw-cost-row">' +
      '<span class="iw-cost-name">' + escHtml(r.label || ('Cost ' + (i + 1))) + '</span>' +
      '<span class="iw-cost-daily">' + fd((r.amount || 0) / 30) + '/d</span>' +
      '<input class="iw-cost-input iw-profit-cost-input" type="number" min="0" step="1" value="' + (r.amount || 0) + '" data-idx="' + i + '" />' +
      '</div>'
    ).join('');

    const fixedSection =
      '<div class="iw-section-title" style="margin-top:0">Fixed Costs</div>' +
      costRows +
      '<div class="iw-total-row"><span>Total Monthly</span><span style="color:var(--primary)">' + fd(totalMonthly) + '</span></div>';

    //  Daily Breakdown table 
    const colStyle = 'style="display:grid;grid-template-columns:68px 1fr 1fr 1fr 28px;gap:0.4rem;align-items:center"';
    const thStyle = 'style="font-size:0.66rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.05em"';

    const tableHead =
      '<div class="iw-section-title" style="margin-top:1.5rem">Daily Breakdown  Last 30 Days</div>' +
      '<div ' + colStyle + ' style="display:grid;grid-template-columns:68px 1fr 1fr 1fr 28px;gap:0.4rem;align-items:center;padding:5px 0;border-bottom:2px solid var(--border)">' +
      '<div ' + thStyle + '>Date</div>' +
      '<div ' + thStyle + ' style="text-align:right">Revenue</div>' +
      '<div ' + thStyle + ' style="text-align:right">Fixed Cost</div>' +
      '<div ' + thStyle + ' style="text-align:right">Net</div>' +
      '<div ' + thStyle + ' style="text-align:center">OK</div>' +
      '</div>';

    const mockNote = !revLoaded
      ? '<div style="font-size:0.72rem;color:var(--muted);font-style:italic;padding:0.35rem 0 0.1rem">Using simulated revenue  live data loading</div>'
      : '';

    const tableRows = days.map(d => {
      const rev = revMap[d] || 0;
      const net = rev - dailyCost;
      const isPos = net >= 0;
      const netColor = isPos ? 'var(--green)' : 'var(--red)';
      const status = rev > 0 ? (isPos ? '' : '') : '';
      return '<div style="display:grid;grid-template-columns:68px 1fr 1fr 1fr 28px;gap:0.4rem;align-items:center;padding:6px 0;border-bottom:1px solid rgba(219,234,254,0.4);font-size:0.82rem">' +
        '<span style="color:var(--muted)">' + fmtDate(d) + '</span>' +
        '<span style="text-align:right;font-weight:700">' + (rev > 0 ? fd(rev) : '') + '</span>' +
        '<span style="text-align:right;color:var(--muted)">' + fd(dailyCost) + '</span>' +
        '<span style="text-align:right;font-weight:800;color:' + netColor + '">' + (rev > 0 ? (isPos ? '+' : '') + fd(net) : '') + '</span>' +
        '<span style="text-align:center">' + status + '</span>' +
        '</div>';
    }).join('');

    return pills + fixedSection + tableHead + mockNote + tableRows;
  }

  function renderCostDrawer() {
    const fixed = (typeof clinicFixedCosts === 'function') ? clinicFixedCosts() : [];
    const utility = (typeof clinicUtilityCosts === 'function') ? clinicUtilityCosts() : [];
    const totalFixed = fixed.reduce((s, r) => s + (parseFloat(r.amount) || 0), 0);
    const totalUtility = utility.reduce((s, r) => s + (parseFloat(r.amount) || 0), 0);
    const total = totalFixed + totalUtility;

    function makeRows(rows, type) {
      if (!rows.length) return '<div style="color:var(--muted);font-size:0.83rem;padding:0.4rem 0">No costs  configure in Settings.</div>';
      return rows.map((r, i) =>
        '<div class="iw-cost-row">' +
        '<span class="iw-cost-name">' + (r.label || 'Unnamed') + '</span>' +
        '<span class="iw-cost-daily">' + fd((parseFloat(r.amount) || 0) / 30) + '/d</span>' +
        '<input class="iw-cost-input" type="number" min="0" step="0.01" value="' + (parseFloat(r.amount) || 0).toFixed(2) + '" data-type="' + type + '" data-idx="' + i + '" />' +
        '</div>'
      ).join('');
    }

    return '<div class="iw-section-title">Fixed Costs</div>' +
      makeRows(fixed, 'fixed') +
      '<div class="iw-section-title">Utility Costs</div>' +
      makeRows(utility, 'utility') +
      '<div class="iw-total-row"><span>Total Monthly</span><span style="color:var(--primary)">' + fd(total) + '</span></div>' +
      '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1rem">' +
      '<div class="iw-metric"><div class="iw-metric-label">Cost Per Day (30)</div><div class="iw-metric-value" style="color:var(--primary)">' + fd(total / 30) + '</div></div>' +
      '<div class="iw-metric"><div class="iw-metric-label">Cost Per Working Day (22)</div><div class="iw-metric-value" style="color:var(--primary)">' + fd(total / 22) + '</div></div>' +
      '</div>' +
      '<div class="iw-save-note" id="iwCostSaveNote"></div>';
  }

  function attachCostInputListeners() {
    const body = document.getElementById('iwDrawerBody');
    if (!body) return;
    body.querySelectorAll('.iw-cost-input').forEach(inp => {
      inp.addEventListener('change', function() {
        const type = this.dataset.type;
        const idx = parseInt(this.dataset.idx, 10);
        const val = parseFloat(this.value) || 0;
        if (typeof ClinicSettings !== 'undefined' && ClinicSettings.updateRow) {
          ClinicSettings.updateRow(type, idx, 'amount', val.toString());
          // Refresh drawer content
          setTimeout(() => {
            const b = document.getElementById('iwDrawerBody');
            if (b) { b.innerHTML = renderCostDrawer(); attachCostInputListeners(); }
            updateWidgetCards();
            const note = document.getElementById('iwCostSaveNote');
            if (note) { note.textContent = 'Saved'; setTimeout(() => { if (note) note.textContent = ''; }, 2000); }
          }, 100);
        }
      });
    });
  }

  function attachProfitInputListeners() {
    const body = document.getElementById('iwDrawerBody');
    if (!body) return;
    body.querySelectorAll('.iw-profit-cost-input').forEach(inp => {
      inp.addEventListener('change', function() {
        const idx = parseInt(this.dataset.idx, 10);
        const val = parseFloat(this.value) || 0;
        if (profitFixedCosts && idx < profitFixedCosts.length) {
          profitFixedCosts[idx].amount = val;
          // Sync to ClinicSettings if we loaded from there
          if (typeof ClinicSettings !== 'undefined' && ClinicSettings.updateRow) {
            const cs = (typeof clinicFixedCosts === 'function') ? clinicFixedCosts() : [];
            if (cs && idx < cs.length) {
              ClinicSettings.updateRow('fixed', idx, 'amount', val.toString());
            }
          }
        }
        const b = document.getElementById('iwDrawerBody');
        if (b) { b.innerHTML = renderProfitDrawer(); attachProfitInputListeners(); }
        updateWidgetCards();
      });
    });
  }

  function renderRevenueDrawer() {
    const days = getLast30Days();
    if (!revLoaded) {
      return '<div style="text-align:center;padding:3rem 0;color:var(--muted)"><div class="spinner" style="margin:0 auto 0.75rem"></div>Loading revenue data</div>';
    }
    const revVals = days.map(d => dailyRevMap[d] || 0);
    const maxVal = Math.max(...revVals, 1);
    const totalRev = revVals.reduce((s, v) => s + v, 0);
    const avgRev = totalRev / 30;

    const bars = days.map((d, i) => {
      const rev = revVals[i];
      const pct = rev > 0 ? Math.max(4, Math.round((rev / maxVal) * 100)) : 0;
      return '<div class="iw-rev-bar-wrap">' +
        '<span class="iw-rev-bar-date">' + fmtDate(d) + '</span>' +
        '<div class="iw-rev-bar-track"><div class="iw-rev-bar-fill" style="width:' + pct + '%"></div></div>' +
        '<span class="iw-rev-bar-val">' + (rev > 0 ? fd(rev) : '') + '</span>' +
        '</div>';
    }).join('');

    const nonZero = revVals.filter(v => v > 0);
    const best = nonZero.length ? Math.max(...nonZero) : 0;
    const worst = nonZero.length ? Math.min(...nonZero) : 0;

    return '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-bottom:1.5rem">' +
      '<div class="iw-metric"><div class="iw-metric-label">Avg Daily Revenue</div><div class="iw-metric-value" style="color:var(--primary)">' + fd(avgRev) + '</div></div>' +
      '<div class="iw-metric"><div class="iw-metric-label">Best Day</div><div class="iw-metric-value" style="color:var(--green)">' + fd(best) + '</div></div>' +
      '<div class="iw-metric"><div class="iw-metric-label">Worst Day</div><div class="iw-metric-value" style="color:var(--red)">' + fd(worst) + '</div></div>' +
      '</div>' +
      bars;
  }

  function init() {
    updateWidgetCards();
    if (!fetchStarted) {
      fetchStarted = true;
      fetchRevenue();
    }
  }

  return { init, openDrawer, closeDrawer };
})();

// Initialize widget board on DOM ready
document.addEventListener('DOMContentLoaded', function() {
  WidgetBoard.init();
  ClinicSettings.init();
  loadServiceData(); // Load service data for baseline + chart

  const origShowTab = window.showTab;
  window.showTab = function(name, btn) {
    origShowTab(name, btn);
    if (name === 'insights') InsightsDashboard.init();
  };
});

// ========== CAMPAIGN TRACKING v1.1 ==========
const CampaignUI = (() => {
  const campaigns = { inflation: 1, '99-pricing': 2, 'micro-margin': 3, 'shoppables': 4 };
  
  async function loadCampaignState() {
    for (const [type, num] of Object.entries(campaigns)) {
      try {
        const res = await fetch(`https://rnqhhzatlxmyvccdvqkr.supabase.co/rest/v1/campaigns?select=*&clinic_id=eq.rosslyn&campaign_type=eq.${type}&status=eq.active&limit=1`, {
          headers: {
            apikey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30',
            Authorization: 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30'
          }
        });
        const data = await res.json();
        if (data && data[0]) {
          updateCampaignUI(type, data[0]);
        }
      } catch (e) {
        console.warn('Campaign state load failed:', type, e);
      }
    }
  }

  function updateCampaignUI(type, campaign) {
    const num = campaigns[type];
    const statusBadge = document.getElementById(`c${num}StatusBadge`);
    const activateBtn = document.getElementById(`c${num}ActivateBtn`);
    const progressDiv = document.getElementById(`c${num}Progress`);
    const progressFill = document.getElementById(`c${num}ProgressFill`);
    const progressLabel = document.getElementById(`c${num}ProgressLabel`);
    const statusDiv = document.getElementById(`c${num}Status`);

    if (campaign && campaign.status === 'active') {
      // Show active state
      statusBadge.className = 'badge active';
      statusBadge.innerHTML = '<span>&#10003;</span> Active';
      activateBtn.style.display = 'none';
      progressDiv.style.display = 'flex';
      
      const pct = campaign.total_items > 0 ? (campaign.implemented_items / campaign.total_items * 100) : 0;
      progressFill.style.width = pct + '%';
      progressLabel.textContent = `${campaign.implemented_items}/${campaign.total_items} implemented`;
      
      // Update summary badge
      const summary = document.getElementById(`c${num}Summary`);
      if (summary) {
        const captured = fmt$(campaign.total_captured || 0);
        const potential = fmt$(campaign.total_potential || 0);
        summary.innerHTML = `
          <div style="font-size:0.72rem;color:var(--muted)">Captured</div>
          <div style="font-size:1.3rem;font-weight:800;color:#16a34a">${captured}</div>
          <div style="font-size:0.72rem;color:var(--muted)">of ${potential} potential</div>
        `;
      }
    } else {
      // Inactive state
      statusBadge.className = 'badge inactive';
      statusBadge.innerHTML = '<span>&#9679;</span> Not Started';
      activateBtn.style.display = 'inline-flex';
      progressDiv.style.display = 'none';
    }
  }

  function fmt$(n) {
    if (n == null || isNaN(n)) return '$0';
    return '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  return { loadCampaignState, updateCampaignUI, campaigns };
})();

// Activate campaign
window.activateCampaign = async function(type) {
  const num = CampaignUI.campaigns[type];
  const btn = document.getElementById(`c${num}ActivateBtn`);
  const badge = document.getElementById(`c${num}StatusBadge`);
  
  btn.disabled = true;
  btn.innerHTML = 'Activating...';
  badge.className = 'badge';
  badge.innerHTML = 'Loading...';

  try {
    // Get items from the campaign data
    const items = type === 'inflation' ? window.c1Items || [] :
                  type === '99-pricing' ? window.c2Items || [] :
                  window.c3Items || [];
    
    if (!items.length) throw new Error('No items to track');

    // Create campaign
    const res = await fetch('https://rnqhhzatlxmyvccdvqkr.supabase.co/rest/v1/campaigns', {
      method: 'POST',
      headers: {
        apikey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30',
        Authorization: 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30',
        'Content-Type': 'application/json',
        Prefer: 'return=representation'
      },
      body: JSON.stringify({
        clinic_id: 'rosslyn',
        campaign_type: type,
        name: type === 'inflation' ? 'Inflation Price Adjustment' :
              type === '99-pricing' ? '.99 Pricing Recovery' : 'Inventory Micro Margin',
        status: 'active',
        activated_at: new Date().toISOString(),
        total_items: items.length,
        implemented_items: 0,
        total_potential: items.reduce((s, i) => s + (i.uplift || 0), 0),
        total_captured: 0
      })
    });
    const [campaign] = await res.json();
    
    // Create approval queue items
    const campaignItems = items.slice(0, 100).map(item => ({
      clinic_id: 'rosslyn',
      campaign_id: campaign.id,
      service_code: item.id || item.code,
      service_name: item.name,
      old_price: item.price,
      suggested_price: item.suggested,
      price_increase_pct: item.price > 0 ? ((item.suggested - item.price) / item.price * 100) : 0,
      expected_monthly_uplift: (item.uplift || 0) / 12,
      expected_annual_uplift: item.uplift || 0,
      volume_risk: 'low',
      status: 'pending',
      priority: 1
    }));

    await fetch(`${SB_URL}/rest/v1/std_approval_queue`, {
      method: 'POST',
      headers: {
        apikey: SB_KEY,
        Authorization: 'Bearer ' + SB_KEY,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(campaignItems)
    });

    CampaignUI.updateCampaignUI(type, campaign);
  } catch (e) {
    console.error('Activation failed:', e);
    badge.className = 'badge inactive';
    badge.innerHTML = '<span>&#10007;</span> Failed';
    btn.disabled = false;
    btn.innerHTML = 'Start Campaign';
  }
};

// Analytics modal
window.openCampaignAnalytics = async function(type) {
  const modal = document.getElementById('campaignModal');
  const title = document.getElementById('modalTitle');
  const body = document.getElementById('modalBody');
  
  title.textContent = type === 'inflation' ? 'Inflation Price Adjustment - Analytics' :
                      type === '99-pricing' ? '.99 Pricing Recovery - Analytics' :
                      'Inventory Micro Margin - Analytics';
  body.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted)">Loading...</div>';
  modal.classList.add('open');

  try {
    // Get campaign
    const res = await fetch(`https://rnqhhzatlxmyvccdvqkr.supabase.co/rest/v1/campaigns?select=*&clinic_id=eq.rosslyn&campaign_type=eq.${type}&status=eq.active&limit=1`, {
      headers: {
        apikey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30',
        Authorization: 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30'
      }
    });
    const campaigns = await res.json();
    const campaign = campaigns[0];

    if (!campaign) {
      body.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted)">No active campaign found.</div>';
      return;
    }

    // Get approval queue items
    const itemsRes = await fetch(`${SB_URL}/rest/v1/std_approval_queue?select=*&campaign_id=eq.${campaign.id}&order=expected_annual_uplift.desc&clinic_id=eq.rosslyn`, {
      headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY }
    });
    const items = await itemsRes.json();

    const fmt$ = n => '$' + (n || 0).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    const pct = campaign.total_items > 0 ? Math.round(campaign.implemented_items / campaign.total_items * 100) : 0;

    body.innerHTML = `
      <div class="analytics-grid">
        <div class="stat-card">
          <div class="label">Total Items</div>
          <div class="value">${campaign.total_items}</div>
        </div>
        <div class="stat-card success">
          <div class="label">Implemented</div>
          <div class="value">${campaign.implemented_items} <span style="font-size:0.8em;font-weight:500">(${pct}%)</span></div>
        </div>
        <div class="stat-card">
          <div class="label">Captured Revenue</div>
          <div class="value" style="color:#16a34a">${fmt$(campaign.total_captured)}</div>
        </div>
        <div class="stat-card warning">
          <div class="label">Remaining Potential</div>
          <div class="value">${fmt$((campaign.total_potential || 0) - (campaign.total_captured || 0))}</div>
        </div>
      </div>
      
      <div class="chart-wrap">
        <div class="chart-title">Implementation Progress</div>
        <canvas id="progressChart" height="60"></canvas>
      </div>
      
      <div style="margin-bottom:0.75rem;font-size:0.8rem;font-weight:700;color:#1e293b">Approval Queue</div>
      <div class="items-list">
        <div class="items-list-header">
          <span>Item</span>
          <span>Current</span>
          <span>Suggested</span>
          <span>Uplift/Yr</span>
          <span>Actions</span>
        </div>
        ${items.slice(0, 50).map(item => `
          <div class="items-list-row">
            <span title="${escHtml(item.service_name || item.service_code)}">${escHtml(item.service_code)}</span>
            <span>${fmt$(item.old_price)}</span>
            <span style="color:var(--primary);font-weight:600">${fmt$(item.suggested_price)}</span>
            <span style="color:#16a34a">${fmt$(item.expected_annual_uplift)}</span>
            <span>${item.status === 'approved' ? '<span class="status-badge implemented">&#10003; Approved</span>' : item.status === 'dismissed' ? '<span class="status-badge skipped">Dismissed</span>' : '<button onclick="approveQueueItem('+item.id+')" style="background:#16a34a;color:#fff;border:none;padding:2px 8px;border-radius:4px;font-size:0.7rem;cursor:pointer;margin-right:3px">&#10003;</button><button onclick="dismissQueueItem('+item.id+')" style="background:#ef4444;color:#fff;border:none;padding:2px 8px;border-radius:4px;font-size:0.7rem;cursor:pointer">&#10005;</button>'}</span>
          </div>
        `).join('')}
      </div>
    `;

    // Draw simple progress chart
    const ctx = document.getElementById('progressChart');
    if (ctx) {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: [''],
          datasets: [{
            label: 'Implemented',
            data: [campaign.implemented_items],
            backgroundColor: '#16a34a'
          }, {
            label: 'Pending',
            data: [campaign.total_items - campaign.implemented_items],
            backgroundColor: '#e2e8f0'
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: { legend: { display: true, position: 'bottom' } },
          scales: { x: { stacked: true, display: false }, y: { stacked: true, display: false } }
        }
      });
    }
  } catch (e) {
    console.error('Analytics load failed:', e);
    body.innerHTML = `<div style="text-align:center;padding:2rem;color:var(--red)">Error loading analytics: ${e.message}</div>`;
  }
};

window.closeCampaignModal = function() {
  document.getElementById('campaignModal').classList.remove('open');
};

window.approveQueueItem = async function(queueId) {
  try {
    const res = await fetch(`${SB_URL}/rest/v1/rpc/approve_recommendation`, {
      method: 'POST',
      headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, 'Content-Type': 'application/json' },
      body: JSON.stringify({ p_queue_id: queueId, p_user_id: '00000000-0000-0000-0000-000000000000' })
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const row = document.querySelector(`button[onclick="approveQueueItem(${queueId})"]`)?.closest('.items-list-row');
    if (row) row.querySelector('span:last-child').innerHTML = '<span class="status-badge implemented">&#10003; Approved</span>';
  } catch(e) { console.error('Approve failed:', e); alert('Approve failed: ' + e.message); }
};

window.dismissQueueItem = async function(queueId) {
  try {
    const reason = prompt('Reason for dismissal (optional):') || 'Dismissed by user';
    const res = await fetch(`${SB_URL}/rest/v1/rpc/dismiss_recommendation`, {
      method: 'POST',
      headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, 'Content-Type': 'application/json' },
      body: JSON.stringify({ p_queue_id: queueId, p_reason: reason })
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const row = document.querySelector(`button[onclick="dismissQueueItem(${queueId})"]`)?.closest('.items-list-row');
    if (row) row.querySelector('span:last-child').innerHTML = '<span class="status-badge skipped">Dismissed</span>';
  } catch(e) { console.error('Dismiss failed:', e); alert('Dismiss failed: ' + e.message); }
};

