<div class="uplift-board">
  <div class="uplift-header"><span class="uplift-title">Key Indicators</span></div>
  <div class="uplift-cards">
    <div class="uplift-card">
      <div class="uplift-card-label">Annual Revenue Opportunity</div>
      <div class="uplift-card-value ub-green" id="ub-annual">--</div>
      <div class="uplift-card-sub">Total Possible Uplift (Annual)</div>
    </div>
    <div class="uplift-card">
      <div class="uplift-card-label">Typical Month</div>
      <div class="uplift-card-value ub-blue" id="ub-baseline-month">--</div>
      <div class="uplift-card-sub">Avg Revenue / Month (3mo)</div>
    </div>
    <div class="uplift-card">
      <div class="uplift-card-label">Last 30 Days Extra Revenue</div>
      <div class="uplift-card-value ub-green" id="ub-campaign-month">--</div>
      <div class="uplift-card-sub">From Pricing Campaigns</div>
    </div>
  </div>
  <div class="uplift-cards" style="margin-top:1rem">
    <div class="uplift-card">
      <div class="uplift-card-label">Total Extra Revenue</div>
      <div class="uplift-card-value ub-green" id="ub-captured-total">--</div>
      <div class="uplift-card-sub">Since Campaign Activation</div>
    </div>
    <div class="uplift-card">
      <div class="uplift-card-label">Extra Revenue Yesterday</div>
      <div class="uplift-card-value ub-green" id="ub-captured-yesterday">--</div>
      <div class="uplift-card-sub">Last 24 Hours</div>
    </div>
  </div>
  <!-- Avg Transaction Value Chart - Full Width -->
  <div class="uplift-chart-card" style="margin-top:1.25rem">
    <div class="uplift-chart-header">
      <div>
        <div class="uplift-chart-title">Average Transaction Value</div>
        <div class="uplift-chart-sub">90-day rolling average per service line item</div>
      </div>
      <div class="uplift-chart-stats">
        <div class="uplift-chart-stat">
          <span class="stat-label">Current</span>
          <span class="stat-value" id="chart-current">--</span>
        </div>
        <div class="uplift-chart-stat">
          <span class="stat-label">30d Avg</span>
          <span class="stat-value" id="chart-avg30">--</span>
        </div>
        <div class="uplift-chart-stat">
          <span class="stat-label">Trend</span>
          <span class="stat-value" id="chart-trend">--</span>
        </div>
      </div>
    </div>
    <div style="height:160px;margin-top:1rem">
      <canvas id="avgTxnChart"></canvas>
    </div>
  </div>
  <div class="uplift-breakdown" style="margin-top:1.25rem">
    <div class="uplift-breakdown-title">Campaign Breakdown</div>
    <div class="uplift-breakdown-items">
      <div class="uplift-breakdown-item">
        <span class="uplift-breakdown-label">Inflation Adjustment</span>
        <span class="uplift-breakdown-value" id="ub-c1">--</span>
      </div>
      <div class="uplift-breakdown-item">
        <span class="uplift-breakdown-label">.99 Pricing</span>
        <span class="uplift-breakdown-value" id="ub-c2">--</span>
      </div>
      <div class="uplift-breakdown-item">
        <span class="uplift-breakdown-label">Micro Margin</span>
        <span class="uplift-breakdown-value" id="ub-c3">--</span>
      </section><!-- SECTION 2: Campaigns
 --><section id="tab-campaigns" class="section"><div id="campaignsLoading" class="loading"><div class="spinner"></div> Analyzing pricing opportunities
 </div><div id="campaignsContent" style="display:none">
  <div style="display:flex;justify-content:flex-end;gap:10px;padding:0 1.75rem 0.8rem 1.75rem">

  </div>
  <!-- Campaign 1: Inflation Adjuster --><div class="campaign-card c-blue"><div class="campaign-header"><div class="campaign-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></div><div class="campaign-meta"><div class="campaign-title">Inflation Price Adjustment Report</div><div class="campaign-desc">Uses real price history (exact last-modified date per item) and actual transaction volume over the last 365 days. Canadian CPI is compounded from the last price change to today &mdash; showing exactly what each item should cost now and the annual revenue left on the table.</div><div class="campaign-status" id="c1Status">
      <span class="campaign-badge" id="c1Badge" style="display:none"></span><div class="badge inactive" id="c1StatusBadge"><span>&#9679;</span> Not Started</div>
      <button class="btn-activate primary" id="c1ActivateBtn" onclick="activateCampaign('inflation')">Start Campaign</button>
      <button class="implement-btn" onclick="openCampaignImplement('inflation')" style="margin-left:8px">Implement Campaign</button>
      <button class="report-btn" onclick="generateReport('inflation')" style="margin-left:8px">PDF Report</button>
     </div>
     <div class="campaign-progress" id="c1Progress" style="display:none">
      <div class="progress-bar-wrap"><div class="progress-bar"><div class="fill" id="c1ProgressFill" style="width:0%"></div></div></div>
      <div class="progress-label" id="c1ProgressLabel">0/0 implemented</div>
      <button class="btn-analytics" onclick="openCampaignAnalytics('inflation')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg> Analytics</button>
     </div></div></div><div id="c1Summary" style="display:flex;gap:2rem;padding:1rem 1.75rem;border-bottom:1px solid var(--border);background:#f8faff;flex-wrap:wrap"></div><button class="campaign-toggle" onclick="toggleCampaign(this)">See More <span class="toggle-arrow">&#9662;</span></button><div class="campaign-body"><div style="padding:0.6rem 1.75rem;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap"><span style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-right:0.5rem">Show:</span><button class="c1-filter active" onclick="c1Filter(this,'all')">All Behind</button><button class="c1-filter" onclick="c1Filter(this,'used')">With Usage Only</button><button class="c1-filter" onclick="c1Filter(this,'urgent')">Urgent (&gt;15%)</button></div><div class="table-scroll"><table><thead><tr><th>Code</th><th>Description</th><th class="num">Last Changed</th><th class="num">Days Stale</th><th class="num">Infl. %</th><th class="num">Current Price</th><th class="num">Suggested Price</th><th class="num">Delta</th><th class="num">Usage / yr</th><th class="num">Est. Uplift / yr</th></tr></thead><tbody id="c1Table"></tbody></table></div></div></div><!-- Campaign 2: .99 Pricing Opportunity --><div class="campaign-card c-purple"><div class="campaign-header"><div class="campaign-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 100 4h4a2 2 0 110 4H8"/><path d="M12 6v2m0 8v2"/></svg></div><div class="campaign-meta"><div class="campaign-title">.99 Pricing Revenue Recovery</div><div class="campaign-desc">Based on actual transaction history: if every line item that <em>wasn't</em> already at a .99 price had been rounded up to the next .99, how much additional revenue would the clinic have captured last year? This shows real missed dollars &mdash; not theory.</div><div class="campaign-status" id="c2Status">
      <span class="campaign-badge" id="c2Badge" style="display:none"></span><div class="badge inactive" id="c2StatusBadge"><span>&#9679;</span> Not Started</div>
      <button class="btn-activate primary" id="c2ActivateBtn" onclick="activateCampaign('99-pricing')">Start Campaign</button>
      <button class="implement-btn" onclick="openCampaignImplement('99-pricing')" style="margin-left:8px">Implement Campaign</button>
      <button class="report-btn" onclick="generateReport('99-pricing')" style="margin-left:8px">PDF Report</button>
     </div>
     <div class="campaign-progress" id="c2Progress" style="display:none">
      <div class="progress-bar-wrap"><div class="progress-bar"><div class="fill" id="c2ProgressFill" style="width:0%"></div></div></div>
      <div class="progress-label" id="c2ProgressLabel">0/0 implemented</div>
      <button class="btn-analytics" onclick="openCampaignAnalytics('99-pricing')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg> Analytics</button>
     </div></div></div><!-- Summary stat bar --><div id="c2Summary" style="display:flex;gap:2rem;padding:1rem 1.75rem;border-bottom:1px solid var(--border);background:#f8faff;flex-wrap:wrap"></div><button class="campaign-toggle" onclick="toggleCampaign(this)">See More <span class="toggle-arrow">&#9662;</span></button><div class="campaign-body"><div class="table-scroll"><table><thead><tr><th>Service / Item</th><th>Category</th><th class="num">Current Price</th><th class="num">.99 Price</th><th class="num">Gain / Txn</th><th class="num">Annual Volume</th><th class="num">Annual Uplift</th></tr></thead><tbody id="c2Table"></tbody></table></div></div></div><!-- Campaign 3: Inventory Micro Margin --><div class="campaign-card c-emerald"><div class="campaign-header"><div class="campaign-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div><div class="campaign-meta"><div class="campaign-title">Inventory Micro Margin</div><div class="campaign-desc">Inventory items (drugs, supplies) with price changes in the last 365 days. When a supplier raises costs and you update the selling price, add an extra 5% margin bump. Shows units sold since the price change and what the extra margin would have been.</div><div class="campaign-status" id="c3Status">
      <span class="campaign-badge" id="c3Badge" style="display:none"></span><div class="badge inactive" id="c3StatusBadge"><span>&#9679;</span> Not Started</div>
      <button class="btn-activate primary" id="c3ActivateBtn" onclick="activateCampaign('micro-margin')">Start Campaign</button>
      <button class="implement-btn" onclick="openCampaignImplement('micro-margin')" style="margin-left:8px">Implement Campaign</button>
      <button class="report-btn" onclick="generateReport('micro-margin')" style="margin-left:8px">PDF Report</button>
     </div>
     <div class="campaign-progress" id="c3Progress" style="display:none">
      <div class="progress-bar-wrap"><div class="progress-bar"><div class="fill" id="c3ProgressFill" style="width:0%"></div></div></div>
      <div class="progress-label" id="c3ProgressLabel">0/0 implemented</div>
      <button class="btn-analytics" onclick="openCampaignAnalytics('micro-margin')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg> Analytics</button>
     </div></div></div><div id="c3Summary" style="display:flex;gap:2rem;padding:1rem 1.75rem;border-bottom:1px solid var(--border);background:#f8faff;flex-wrap:wrap"></div><button class="campaign-toggle" onclick="toggleCampaign(this)">See More <span class="toggle-arrow">&#9662;</span></button><div class="campaign-body"><div class="table-scroll"><table><thead><tr><th>Item</th><th class="num">Price Increase</th><th class="num">Current &rarr; +5% Bump</th><th class="num">Annual Volume</th><th class="num">Extra Margin / Year</th></tr></thead><tbody id="c3Table"></tbody></table></div></div></div><!-- Campaign 4: Shoppables — Exam Drop Initiative --><div class="campaign-card" style="border-left:4px solid #f59e0b"><div class="campaign-header"><div class="campaign-icon" style="background:linear-gradient(135deg,#f59e0b,#fbbf24)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></div><div class="campaign-meta"><div class="campaign-title">Shoppables — Exam Drop Initiative</div><div class="campaign-desc">Drop exam prices to attract new patients. Top pairing items get a bump to recover the gap. Drag the slider to explore scenarios.</div><div class="campaign-status" id="c4Status">
      <span class="campaign-badge" id="c4Badge" style="display:none"></span><div class="badge inactive" id="c4StatusBadge"><span>&#9679;</span> Not Started</div>
      <button class="btn-activate primary" id="c4ActivateBtn" onclick="activateShoppables()">Start Campaign</button>
