</div></section><script>
// 
// Utilities
// 
function fmt$(n) { return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }
function fmtN(n) { return n.toLocaleString(); }
function fmtPct(n) { return (n * 100).toFixed(1) + '%'; }
function escHtml(str) {
 return String(str)
 .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

const MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

function parseTxnDate(str) {
 if (!str) return null;
 const parts = str.split(' ')[0].split('/');
 if (parts.length < 3) return null;
 const month = parseInt(parts[0], 10);
 const year = parseInt(parts[2], 10);
 if (isNaN(month) || isNaN(year)) return null;
 return { year, month, key: `${year}-${String(month).padStart(2,'0')}` };
}

function parseTxnDateISO(str) {
 if (!str) return null;
 const k = str.slice(0, 7);
 const year = parseInt(k.slice(0, 4), 10);
 const month = parseInt(k.slice(5, 7), 10);
 if (isNaN(year) || isNaN(month)) return null;
 return { year, month, key: k };
}

function monthLabel(key) {
 const [y, m] = key.split('-');
 return MONTH_NAMES[parseInt(m,10)-1] + ' ' + y.slice(2);
}

function sortMonthKeys(keys) {
 return keys.slice().sort((a,b) => a.localeCompare(b));
}

Chart.defaults.color = '#64748b';
Chart.defaults.borderColor = 'rgba(219,234,254,0.8)';
Chart.defaults.font.family = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
Chart.defaults.font.size = 11;

// 
// Campaign Toggle
// 
function toggleCampaign(btn) {
 const body = btn.nextElementSibling;
 const isOpen = body.classList.toggle('open');
 btn.classList.toggle('open', isOpen);
 btn.innerHTML = (isOpen ? 'See Less' : 'See More') + ' <span class="toggle-arrow">&#9662;</span>';
}

// 
// Tab Switching
// 
function renderInventory(){
 var data=window._invUsage||[];
 var q=(document.getElementById("invSearch")||{}).value||"";
 var mf=(document.getElementById("invMarginFilter")||{}).value||"all";
 if(q){var ql=q.toLowerCase();data=data.filter(r=>(r.name||"").toLowerCase().includes(ql)||(r.code||"").toLowerCase().includes(ql));}
 if(mf==="profitable")data=data.filter(r=>r.margin_pct>0);
 else if(mf==="loss")data=data.filter(r=>r.margin_pct<0);
 else if(mf==="high")data=data.filter(r=>r.margin_pct>50);
 // KPIs
 var totRev=0,totCogs=0,totItems=data.length;
 data.forEach(r=>{totRev+=r.total_revenue;totCogs+=r.total_cogs;});
 var totGp=totRev-totCogs,totMargin=totRev>0?totGp/totRev*100:0;
 var kpiEl=document.getElementById("invKpis");
 if(kpiEl)kpiEl.innerHTML=
   '<div style="text-align:center"><div style="font-size:0.65rem;font-weight:700;color:var(--muted);text-transform:uppercase">Items</div><div style="font-size:1.1rem;font-weight:800">'+totItems+'</div></div>'+
   '<div style="text-align:center"><div style="font-size:0.65rem;font-weight:700;color:var(--muted);text-transform:uppercase">Revenue</div><div style="font-size:1.1rem;font-weight:800;color:var(--primary)">'+fmt$(totRev)+'</div></div>'+
   '<div style="text-align:center"><div style="font-size:0.65rem;font-weight:700;color:var(--muted);text-transform:uppercase">Est. COGS</div><div style="font-size:1.1rem;font-weight:800;color:#ef4444">'+fmt$(totCogs)+'</div></div>'+
   '<div style="text-align:center"><div style="font-size:0.65rem;font-weight:700;color:var(--muted);text-transform:uppercase">Margin</div><div style="font-size:1.1rem;font-weight:800;color:'+(totMargin>=50?"#16a34a":"#ca8a04")+'">'+totMargin.toFixed(1)+'%</div></div>';
 // Table
 var tb=document.getElementById("invTable");
 if(!tb)return;
 tb.innerHTML=data.map(r=>{
   var mc=r.margin_pct>=50?"#16a34a":r.margin_pct>=0?"#ca8a04":"#ef4444";
   return '<tr style="border-bottom:1px solid var(--border)">'+
     '<td style="padding:0.45rem 0.75rem"><div style="font-weight:600">'+escHtml(r.name||r.code)+'</div><div style="font-size:0.7rem;color:var(--muted)">'+r.code+' → '+r.service_code+'</div></td>'+
     '<td style="text-align:right;padding:0.45rem 0.75rem">'+fmt$(r.unit_cost)+'</td>'+
     '<td style="text-align:right;padding:0.45rem 0.75rem">'+fmtN(Math.round(r.total_qty))+'</td>'+
     '<td style="text-align:right;padding:0.45rem 0.75rem;font-weight:600;color:var(--primary)">'+fmt$(r.total_revenue)+'</td>'+
     '<td style="text-align:right;padding:0.45rem 0.75rem;color:#ef4444">'+fmt$(r.total_cogs)+'</td>'+
     '<td style="text-align:right;padding:0.45rem 0.75rem;color:'+mc+'">'+fmt$(r.gross_profit)+'</td>'+
     '<td style="text-align:right;padding:0.45rem 0.75rem;font-weight:700;color:'+mc+'">'+r.margin_pct.toFixed(1)+'%</td>'+
     '<td style="text-align:right;padding:0.45rem 0.75rem">'+r.txn_count+'</td></tr>';
 }).join('');
}
function showTab(name, btn) {
 document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
 document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
 document.getElementById('tab-' + name).classList.add('active');
 if (btn) btn.classList.add('active');
 if (name === 'settings') ClinicSettings.init();
}

//  Supabase 
const SB_URL = 'https://rnqhhzatlxmyvccdvqkr.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJucWhoemF0bHhteXZjY2R2cWtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwMTQ5ODUsImV4cCI6MjA5MDU5MDk4NX0.zokle21pVEPG5bIOFiyZIWYkYIwhkolWNOhJ7Cbub30';

async function sbFetch(table, params) {
 const res = await fetch(`${SB_URL}/rest/v1/${table}?${params}`, {
   headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, Accept: 'application/json' }
 });
 if (!res.ok) throw new Error('SB ' + res.status);
 return res.json();
}

async function sbFetchAll(table, params) {
 const headers = { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, Accept: 'application/json', Prefer: 'count=exact' };
 let all = [], from = 0, total = Infinity;
 const MAX_ROWS = 50000; // Limit to 50K rows to avoid Supabase pagination issues
 while (from < total && all.length < MAX_ROWS) {
   const to = from + 999;
   try {
     const res = await fetch(`${SB_URL}/rest/v1/${table}?${params}&offset=${from}&limit=1000`, {
       headers
     });
     if (res.status === 500) {
       console.warn(`SB 500 at offset ${from}, stopping pagination (got ${all.length} rows)`);
       break;
     }
     if (!res.ok) throw new Error('SB ' + res.status + ' on ' + table);
     const cr = res.headers.get('content-range');
     if (cr) { const m = cr.match(/\/(\d+)/); if (m) total = parseInt(m[1]); }
     const rows = await res.json();
     if (!rows || rows.length === 0) break;
     all = all.concat(rows);
     from += rows.length;
     if (rows.length < 1000) break;
   } catch(e) {
     console.warn(` Error fetching ${table} at offset ${from}:`, e.message, '(continuing with', all.length, 'rows)');
     break;
   }
 }
 return all;
}

//
// Data Loading
//
let serviceData = null;
let pricesData = null;
let treatmentsData = null;
let itemNamesMap = null;
 let accountsData = null;
let microMarginData = null;
let analyticsReady = false;
let campaignsReady = false;
const campaignCache = {};
const CAMPAIGN_TTL = 7 * 60 * 1000;

// Shared analytics objects (for AI access)
let AI_byService = {};
let AI_byCat = {};
let AI_byMonth = {};
let AI_monthKeys = [];
let AI_totalRevenue = 0; let AI_totalQty = 0;

// Wire inventory search/filter after DOM ready
window.addEventListener("DOMContentLoaded", function(){
  var s=document.getElementById("invSearch"),f=document.getElementById("invMarginFilter");
  if(s)s.addEventListener("input",function(){renderInventory();});
  if(f)f.addEventListener("change",function(){renderInventory();});
});

async function loadDataAndBuild() {
 try {
   const svcRows = await sbFetchAll('service_usage_agg', 'select=code,total_amount,total_qty,txn_count,service_type');
   // Map to expected format for campaigns
   svcRows.forEach(r => { r.amount = r.total_amount / (r.txn_count || 1); r.quantity = r.total_qty; });
   
   const priceRows = await sbFetchAll('prices', 'select=treatment_code,price,updated_at&order=updated_at.asc');
   
   const treatRows = await sbFetchAll('treatments', 'select=code,name,type_flag');
   const itemNameRows = await sbFetchAll('item_names', 'select=code,name');
   itemNamesMap = {};
   for (const r of itemNameRows) itemNamesMap[r.code] = r.name;
   
   const acctRows = await sbFetchAll('accounts', 'select=txn_date,amount_raw,type_flag&order=txn_date.asc');
   
   const mmRows = await sbFetchAll('micro_margin_agg', 'select=code,price,price_changed,sales_since_change,potential_uplift');
   
   serviceData = svcRows;
   pricesData = priceRows;
   treatmentsData = treatRows;
   accountsData = acctRows;
   microMarginData = mmRows;
   
   // Load service catalog from std_services (no unit_cost available)
   const itemRows = await sbFetchAll('std_services', 'select=service_code,name,category&clinic_id=eq.rosslyn');
   const inventoryItems = []; // std_services has no unit_cost; skip COGS calculation
   
   // Build inventory usage from serviceData + items
   const invMap = {};
   for (const item of inventoryItems) {
     if (!invMap[item.service_code]) invMap[item.service_code] = [];
     invMap[item.service_code].push(item);
   }
   const invUsage = [];
   for (const svc of serviceData || []) {
     const code = svc.code;
     const items = invMap[code];
     if (!items) continue;
     for (const item of items) {
       const qty = svc.total_qty || 0;
       const rev = svc.total_amount || 0;
       const cost = item.unit_cost || 0;
       const cogs = cost * qty;
       const gp = rev - cogs;
       invUsage.push({ code: item.code, name: item.name, service_code: code, unit_cost: cost, total_qty: qty, total_revenue: rev, total_cogs: cogs, gross_profit: gp, margin_pct: rev > 0 ? (gp/rev*100) : 0, txn_count: svc.txn_count || 0, service_type: svc.service_type });
     }
   }
   invUsage.sort((a,b) => b.total_revenue - a.total_revenue);
   window._invUsage = invUsage;
   if (document.getElementById('invTable')) renderInventory();
   
   console.log('DATA LOADED:');
   console.log('  serviceData:', serviceData.length, 'rows');
   console.log('  pricesData:', pricesData.length, 'rows');
   console.log('  treatmentsData:', treatmentsData.length, 'rows');
   console.log('  accountsData:', accountsData.length, 'rows');
   if (serviceData.length > 0) console.log('  Sample service:', serviceData[0]);
   if (pricesData.length > 0) console.log('  Sample price:', pricesData[0]);
   
   const ds=document.getElementById('dotService');
   const dc=document.getElementById('dotCatalog');
   const dp=document.getElementById('dotPriceHistory');
   if(ds) ds.classList.add('loaded');
   if(dc) dc.classList.add('loaded');
   if(dp) dp.classList.add('loaded');
   buildAnalytics();
 } catch(e) {
   console.error(' Data load error:', e);
   const el = document.getElementById('campaignsLoading');
   if (el) el.innerHTML = '<div style="color:var(--red);padding:2rem;font-size:0.85rem"><strong>Data Load Error:</strong><br/>' + e.toString() + '</div>';
 }
}

loadDataAndBuild().then(() => {
  var kpiLabel = document.getElementById('kpiDateLabel');
  if (kpiLabel) kpiLabel.textContent = 'All time';
  document.getElementById('lastUpdated').textContent = 'Loaded ' + (serviceData||[]).length.toLocaleString() + ' services';
  return buildCampaigns();
}).catch(e => {
  console.error(' Campaign init error:', e);
  document.getElementById('campaignsLoading').style.display = 'none';
  document.getElementById('campaignsLoading').innerHTML = '<div style="color:var(--red);padding:2rem;font-size:0.9rem"><strong>Error:</strong> ' + e.message + '</div>';
  document.getElementById('campaignsLoading').style.display = 'block';
});

//
// SECTION 1: Analytics & KPIs
//
let analyticsFilterDate = null;

async function filterKPIByDate(dateStr) {
  analyticsFilterDate = dateStr ? new Date(dateStr + 'T12:00:00') : null;
  const label = document.getElementById('kpiDateLabel');
  if (label) {
    label.textContent = analyticsFilterDate ? 'Loading...' : 'All time';
  }
  analyticsReady = false;
  await buildAnalytics();
  if (label && analyticsFilterDate) {
    label.textContent = analyticsFilterDate.toLocaleDateString();
  }
}

async function buildAnalytics() {
 analyticsReady = true;
 const selectedDate = analyticsFilterDate;
 
 let totalRevenue = 0, totalQty = 0, visits = 0, uniqueServices = 0, avgLineAmount = 0;
 const byMonth = {}, byCat = {}, byService = {};

 if (selectedDate) {
   // Day view: fetch from daily_kpis and daily_service_breakdown
   const dayStr = selectedDate.toISOString().slice(0,10);
   const [dayKpi, daySvc] = await Promise.all([
     sbFetch('daily_kpis', 'select=*&txn_day=eq.' + dayStr),
     sbFetch('daily_service_breakdown', 'select=*&txn_day=eq.' + dayStr)
   ]);
   
   if (dayKpi.length) {
     const k = dayKpi[0];
     totalRevenue = k.revenue || 0;
     totalQty = k.line_items || 0;
     visits = k.visits || 0;
     uniqueServices = k.unique_services || 0;
     avgLineAmount = k.avg_line_amount || 0;
   }
   
   // Category + service breakdown for that day
   for (const row of daySvc) {
     const classid = (row.service_type || '').trim();
     const code = row.code;
     if (classid) {
       if (!byCat[classid]) byCat[classid] = { rev: 0 };
       byCat[classid].rev += row.revenue || 0;
     }
     if (code) {
       const name = code;
       if (!byService[name]) byService[name] = { rev: 0, qty: 0, classid };
       byService[name].rev += row.revenue || 0;
       byService[name].qty += row.qty || 0;
     }
   }
   
   // Month key for this day
   const mk = dayStr.slice(0,7);
   byMonth[mk] = { rev: totalRevenue, qty: totalQty };
   
 } else {
   // All-time view: use accounts for monthly trend + serviceData for totals
   for (const row of (accountsData || [])) {
     const tot = (row.amount_raw || 0) / 100;
     const txn = parseTxnDateISO(row.txn_date);
     if (txn) {
       if (!byMonth[txn.key]) byMonth[txn.key] = { rev: 0, qty: 0 };
       byMonth[txn.key].rev += tot;
       byMonth[txn.key].qty += 1;
     }
   }
   let totalLineItems = 0;
   for (const row of (serviceData||[])) {
     const classid = (row.service_type || '').trim();
     const tot = parseFloat(row.total_amount || row.amount) || 0;
     const qty = parseFloat(row.total_qty || row.quantity) || 0;
     const txnCount = parseInt(row.txn_count || 0);
     const code = row.code || 'Unknown';
     totalRevenue += tot;
     totalQty += txnCount || qty;
     totalLineItems += txnCount || 1;
     if (classid) {
       if (!byCat[classid]) byCat[classid] = { rev: 0 };
       byCat[classid].rev += tot;
     }
     if (code) {
       if (!byService[code]) byService[code] = { rev: 0, qty: 0, classid };
       byService[code].rev += tot;
       byService[code].qty += qty;
     }
   }
   avgLineAmount = totalLineItems > 0 ? totalRevenue / totalLineItems : 0;
 }

 // Save for AI and widget board
 AI_byService = byService;
 AI_byCat = byCat;
 AI_byMonth = byMonth;
 AI_totalRevenue = totalRevenue;
 AI_totalQty = totalQty;

 const monthKeys = sortMonthKeys(Object.keys(byMonth));
 AI_monthKeys = monthKeys;

 const dateLabel = selectedDate ? selectedDate.toLocaleDateString() : 'All Time';
 document.getElementById('lastUpdated').textContent = `${dateLabel}  ${fmt$(totalRevenue)} revenue  ${fmtN(totalQty)} transactions`;
 if (selectedDate) {
   document.getElementById('lastUpdated').textContent += `  ${fmtN(visits)} visits  ${fmtN(uniqueServices)} services`;
 }

 window._avgLineAmount = avgLineAmount; refreshUpliftBoard();
 if (typeof WidgetBoard !== 'undefined') WidgetBoard.onCSVReady();
}

