function sCard(label, value, sub, color) {
  return '<div style="text-align:center"><div style="font-size:0.72rem;color:var(--muted)">' + label + '</div><div style="font-size:1.3rem;font-weight:800;color:' + color + '">' + value + '</div><div style="font-size:0.72rem;color:var(--muted)">' + sub + '</div></div>';
}

// Exam drop slider logic
(function() {
  const slider = document.getElementById('c4DropSlider');
  if (!slider) return;
  slider.addEventListener('input', function() {
    const dropAmt = parseInt(this.value);
    document.getElementById('c4DropAmount').textContent = '$' + dropAmt;

    // Show "See the Plan" button with pulse when slider moves
    const planBtn = document.getElementById('c4PlanBtn');
    if (dropAmt > 0) {
      planBtn.style.display = 'inline-block';
      planBtn.classList.add('c4-plan-pulse');
    } else {
      planBtn.style.display = 'none';
      planBtn.classList.remove('c4-plan-pulse');
    }

    // Risk level based on drop amount
    const riskBar = document.getElementById('c4RiskBar');
    const riskBadge = document.getElementById('c4RiskBadge');
    const reqBump = document.getElementById('c4RequiredBump');
    
    let riskLabel, riskColor, riskBg, riskPct;
    if (dropAmt === 0) { riskLabel = 'None'; riskColor = '#16a34a'; riskBg = '#dcfce7'; riskPct = 0; }
    else if (dropAmt <= 5) { riskLabel = 'Low'; riskColor = '#16a34a'; riskBg = '#dcfce7'; riskPct = 10; }
    else if (dropAmt <= 10) { riskLabel = 'Low'; riskColor = '#65a30d'; riskBg = '#ecfccb'; riskPct = 20; }
    else if (dropAmt <= 15) { riskLabel = 'Moderate'; riskColor = '#ca8a04'; riskBg = '#fef9c3'; riskPct = 35; }
    else if (dropAmt <= 20) { riskLabel = 'Moderate'; riskColor = '#ea580c'; riskBg = '#fff7ed'; riskPct = 50; }
    else if (dropAmt <= 30) { riskLabel = 'High'; riskColor = '#dc2626'; riskBg = '#fef2f2'; riskPct = 70; }
    else if (dropAmt <= 40) { riskLabel = 'Very High'; riskColor = '#dc2626'; riskBg = '#fee2e2'; riskPct = 85; }
    else { riskLabel = 'Extreme'; riskColor = '#991b1b'; riskBg = '#fecaca'; riskPct = 100; }
    
    riskBar.style.width = riskPct + '%';
    riskBar.style.background = riskColor;
    riskBadge.textContent = riskLabel;
    riskBadge.style.color = riskColor;
    riskBadge.style.background = riskBg;

    // Calculate required pairing bump % to break even
    if (!serviceData) return;
    const examCodes = ['HC', 'HEF'];
    let examVolume = 0;
    (serviceData || []).forEach(r => {
      if (examCodes.includes(r.code)) {
        examVolume += parseFloat(r.total_amount || 0);
      }
    });
    
    // Total non-exam revenue for pairing bump base
    let pairingRev = 0;
    (serviceData || []).forEach(r => {
      if (!examCodes.includes(r.code)) {
        pairingRev += parseFloat(r.total_amount || 0);
      }
    });

    // Lost revenue = dropAmt * exam_count
    // HC/HEF not in service_usage_agg, use verified count from services table
    let examCount = 565; // verified unique exam transactions (last 12mo, excl ETL spikes)
    const lostRevenue = dropAmt * examCount;
    
    // Required bump % = lostRevenue / pairingRev * 100
    const bumpPct = pairingRev > 0 ? (lostRevenue / pairingRev * 100) : 0;
    reqBump.textContent = bumpPct.toFixed(1) + '%';

    // Re-run projections with this drop amount
    if (typeof recalcShoppables === 'function') recalcShoppables(dropAmt);
  });
})();

async function loadShoppables() {
  try {
    // 1. Check if campaign is active
    const res = await fetch(SB_URL + '/rest/v1/campaigns?select=*&clinic_id=eq.rosslyn&campaign_type=eq.shoppables&status=eq.active&limit=1', {
      headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY }
    });
    const camps = await res.json();
    const isActive = camps && camps.length > 0;

    if (isActive) {
      const camp = camps[0];
      
      // Update badge
      document.getElementById('c4StatusBadge').className = 'badge active';
      document.getElementById('c4StatusBadge').innerHTML = '<span>&#10003;</span> Active';
      document.getElementById('c4ActivateBtn').style.display = 'none';
      document.getElementById('c4ImplementBtn').style.display = 'inline-block';
      document.getElementById('c4ReportBtn').style.display = 'inline-block';
      document.getElementById('c4Slider').style.display = 'none';
      
      // Show progress
      document.getElementById('c4Progress').style.display = 'flex';
      const pct = camp.total_items > 0 ? (camp.implemented_items / camp.total_items * 100) : 0;
      document.getElementById('c4ProgressFill').style.width = pct + '%';
      document.getElementById('c4ProgressLabel').textContent = camp.implemented_items + '/' + camp.total_items + ' implemented';

      // Load approval queue items
      const itemsRes = await fetch(SB_URL + '/rest/v1/std_approval_queue?select=*&campaign_id=eq.' + camp.id + '&order=expected_annual_uplift.desc&clinic_id=eq.rosslyn', {
        headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY }
      });
      const items = await itemsRes.json();
      if (!items || !items.length) return;
      // Normalize field names for downstream rendering
      items.forEach(i => { i.potential_uplift = i.expected_annual_uplift; i.treatment_code = i.service_code; i.treatment_name = i.service_name; });
      window.c4Items = items;

      const drops = items.filter(i => i.potential_uplift < 0);
      const bumps = items.filter(i => i.potential_uplift >= 0);
      const totalLoss = Math.abs(drops.reduce((s, i) => s + i.potential_uplift, 0));
      const totalGain = bumps.reduce((s, i) => s + i.potential_uplift, 0);
      const net = totalGain - totalLoss;

      document.getElementById('c4Summary').innerHTML =
        sCard('Revenue Lost', '-$' + totalLoss.toLocaleString('en-US', { maximumFractionDigits: 0 }), 'exam price drops', 'var(--red)') +
        sCard('Revenue Gained', '+$' + totalGain.toLocaleString('en-US', { maximumFractionDigits: 0 }), 'pairing bumps', 'var(--green)') +
        sCard('Net P&L', (net >= 0 ? '+' : '-') + '$' + Math.abs(net).toLocaleString('en-US', { maximumFractionDigits: 0 }), 'combined', net >= 0 ? 'var(--green)' : 'var(--red)') +
        sCard('Break-Even', (totalLoss > 0 ? Math.min(100, totalGain / totalLoss * 100) : 0).toFixed(0) + '%', 'recovery progress', totalGain >= totalLoss ? 'var(--green)' : 'var(--orange)');

      renderC4Table(items, 'all');
      return;
    }

    // === PREVIEW MODE (no active campaign) ===
    if (!pricesData || !serviceData || !treatmentsData) return;

    const examCodes = ['HC', 'HEF'];
    const examDropPct = 0.10;
    const pairingBumpPct = 0.05;

    const usageMap = {};
    (serviceData || []).forEach(r => {
      if (!r.code) return;
      if (!usageMap[r.code]) usageMap[r.code] = { count: 0, rev: 0 };
      usageMap[r.code].count += (r.txn_count || 1);
      usageMap[r.code].rev += parseFloat(r.total_amount || r.amount) || 0;
    });

    const nameLookup = {};
    (treatmentsData || []).forEach(t => { nameLookup[t.code] = (itemNamesMap && itemNamesMap[t.code]) || t.name || t.code; });

    const priceMap = {};
    (pricesData || []).forEach(p => { if (p.treatment_code && p.price) priceMap[p.treatment_code] = p.price; });

    const projectedItems = [];

    for (const code of examCodes) {
      const price = priceMap[code];
      if (!price) continue;
      const usage = usageMap[code];
      if (!usage) continue;
      const newPrice = Math.round(price * (1 - examDropPct));
      const annualVol = Math.round(usage.rev / price);
      const drop = (price - newPrice) * annualVol;
      projectedItems.push({
        treatment_code: code, treatment_name: nameLookup[code] || code,
        old_price: price, suggested_price: newPrice,
        annual_volume: annualVol, potential_uplift: -drop
      });
    }

    const nonExamCodes = Object.keys(usageMap).filter(c => !examCodes.includes(c) && priceMap[c]).sort((a, b) => usageMap[b].rev - usageMap[a].rev).slice(0, 20);
    for (const code of nonExamCodes) {
      const price = priceMap[code];
      const usage = usageMap[code];
      if (!price || !usage || usage.count < 10) continue;
      const newPrice = Math.ceil(price * (1 + pairingBumpPct) * 100) / 100;
      const annualVol = Math.round(usage.rev / price);
      const bump = (newPrice - price) * annualVol;
      projectedItems.push({
        treatment_code: code, treatment_name: nameLookup[code] || code,
        old_price: price, suggested_price: newPrice,
        annual_volume: annualVol, potential_uplift: bump
      });
    }

    projectedItems.sort((a, b) => b.potential_uplift - a.potential_uplift);
    c4ProjectedItems = projectedItems;
    window.c4Items = projectedItems;

    const drops = projectedItems.filter(i => i.potential_uplift < 0);
    const bumps = projectedItems.filter(i => i.potential_uplift >= 0);
    const totalLoss = Math.abs(drops.reduce((s, i) => s + i.potential_uplift, 0));
    const totalGain = bumps.reduce((s, i) => s + i.potential_uplift, 0);
    const net = totalGain - totalLoss;

    document.getElementById('c4Summary').innerHTML =
      sCard('Revenue at Risk', '-$' + totalLoss.toLocaleString('en-US', { maximumFractionDigits: 0 }), 'exam price drops', 'var(--red)') +
      sCard('Recovery Potential', '+$' + totalGain.toLocaleString('en-US', { maximumFractionDigits: 0 }), 'pairing item bumps', 'var(--green)') +
      sCard('Net Impact', (net >= 0 ? '+' : '-') + '$' + Math.abs(net).toLocaleString('en-US', { maximumFractionDigits: 0 }), 'projected', net >= 0 ? 'var(--green)' : 'var(--red)') +
      sCard('Items', projectedItems.length + '', drops.length + ' drops + ' + bumps.length + ' bumps', 'var(--primary)');

    renderC4Table(projectedItems, 'all');

  } catch (e) {
    console.error('Shoppables load failed:', e);
    document.getElementById('c4Table').innerHTML = '<tr><td colspan="8" style="color:var(--red)">Error: ' + e.message + '</td></tr>';
  }
}

// Recalculate shoppables preview based on slider drop amount
window.recalcShoppables = function(dropAmt) {
  if (!pricesData || !serviceData || !treatmentsData) return;
  
  const examCodes = ['HC', 'HEF'];
  const nameLookup = {};
  (treatmentsData || []).forEach(t => { nameLookup[t.code] = (itemNamesMap && itemNamesMap[t.code]) || t.name || t.code; });
  const priceMap = {};
  (pricesData || []).forEach(p => { if (p.treatment_code && p.price) priceMap[p.treatment_code] = p.price; });

  const usageMap = {};
  (serviceData || []).forEach(r => {
    if (!r.code) return;
    if (!usageMap[r.code]) usageMap[r.code] = { count: 0, rev: 0 };
    usageMap[r.code].count += (r.txn_count || 1);
    usageMap[r.code].rev += parseFloat(r.total_amount || r.amount) || 0;
  });

  const projectedItems = [];

  // Exam drop — 565 total (verified, last 12mo excl ETL spikes)
  const totalExamCount = 565;
  const examPrice = 80;
  const lostRevenue = dropAmt * totalExamCount;

  projectedItems.push({
    treatment_code: 'HC/HEF', treatment_name: 'Health Exam (Canine & Feline)',
    old_price: examPrice, suggested_price: Math.max(0, examPrice - dropAmt),
    annual_volume: totalExamCount, potential_uplift: -lostRevenue,
    pair_count: totalExamCount, is_pairing: false
  });

  if (lostRevenue > 0) {
    // Build a merged list: exam pairings (real co-occurrence) + top revenue services
    // More items = smaller bump per item
    const bumpCandidates = [];
    const seenCodes = new Set();
    
    // Priority 1: Real exam pairings from materialized view
    if (examPairings.length > 0) {
      for (const p of examPairings) {
        const price = priceMap[p.item_code] || p.avg_price;
        if (!price || seenCodes.has(p.item_code)) continue;
        seenCodes.add(p.item_code);
        bumpCandidates.push({
          code: p.item_code,
          name: (itemNamesMap && itemNamesMap[p.item_code]) || p.item_name || p.item_code,
          price: price,
          volume: p.pair_count,
          is_real_pairing: true
        });
      }
    }
    
    // Priority 2: Top revenue non-exam services to spread the bump thinner
    const topServices = Object.keys(usageMap)
      .filter(c => !examCodes.includes(c) && priceMap[c] && !seenCodes.has(c))
      .sort((a, b) => usageMap[b].rev - usageMap[a].rev)
      .slice(0, 35);
    
    for (const code of topServices) {
      const price = priceMap[code];
      const usage = usageMap[code];
      if (!price || !usage || usage.count < 5) continue;
      seenCodes.add(code);
      bumpCandidates.push({
        code: code,
        name: nameLookup[code] || code,
        price: price,
        volume: usage.count,
        is_real_pairing: false
      });
    }
    
    // Uniform bump % = lost / sum(price × volume)
    const totalBase = bumpCandidates.reduce((s, c) => s + (c.price * c.volume), 0);
    const uniformBumpPct = totalBase > 0 ? lostRevenue / totalBase : 0;
    
    for (const cand of bumpCandidates) {
      const newPrice = Math.ceil(cand.price * (1 + uniformBumpPct) * 100) / 100;
      const bump = (newPrice - cand.price) * cand.volume;
      projectedItems.push({
        treatment_code: cand.code, treatment_name: cand.name,
        old_price: cand.price, suggested_price: newPrice,
        annual_volume: cand.volume, potential_uplift: bump,
        pair_count: cand.is_real_pairing ? cand.volume : 0,
        is_pairing: cand.is_real_pairing
      });
    }
  }

  projectedItems.sort((a, b) => b.potential_uplift - a.potential_uplift);
  c4ProjectedItems = projectedItems;
  window.c4Items = projectedItems;

  const drops = projectedItems.filter(i => i.potential_uplift < 0);
  const bumps = projectedItems.filter(i => i.potential_uplift >= 0);
  const totalLoss = Math.abs(drops.reduce((s, i) => s + i.potential_uplift, 0));
  const totalGain = bumps.reduce((s, i) => s + i.potential_uplift, 0);
  const net = totalGain - totalLoss;

  document.getElementById('c4Summary').innerHTML =
    sCard('Revenue at Risk', '-$' + totalLoss.toLocaleString('en-US', { maximumFractionDigits: 0 }), 'exam price drops', 'var(--red)') +
    sCard('Recovery Potential', '+$' + totalGain.toLocaleString('en-US', { maximumFractionDigits: 0 }), 'real pairing bumps', 'var(--green)') +
    sCard('Net Impact', (net >= 0 ? '+' : '-') + '$' + Math.abs(net).toLocaleString('en-US', { maximumFractionDigits: 0 }), 'projected', net >= 0 ? 'var(--green)' : 'var(--red)') +
    sCard('Items Bumped', bumps.length + '', 'across all services', 'var(--primary)');

  renderC4Table(projectedItems, 'all');
};

// Show the Plan popup
window.showC4Plan = function() {
  const planBtn = document.getElementById('c4PlanBtn');
  planBtn.classList.remove('c4-plan-pulse');
  
  const dropAmt = parseInt(document.getElementById('c4DropSlider').value) || 0;
  if (dropAmt === 0) {
    document.getElementById('c4PlanContent').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted)">Set an exam drop amount using the slider above to see the plan.</div>';
    document.getElementById('c4PlanModal').style.display = 'block';
    return;
  }
  
  if (!c4ProjectedItems.length && typeof recalcShoppables === 'function') {
    recalcShoppables(dropAmt);
  }
  
  const items = c4ProjectedItems.length ? c4ProjectedItems : window.c4Items;
  const drops = items.filter(i => i.potential_uplift < 0);
  const bumps = items.filter(i => i.potential_uplift >= 0);
  const totalLoss = Math.abs(drops.reduce((s, i) => s + i.potential_uplift, 0));
  const totalGain = bumps.reduce((s, i) => s + i.potential_uplift, 0);
  const net = totalGain - totalLoss;
  const bumpPct = bumps.length > 0 ? ((bumps[0].suggested_price - bumps[0].old_price) / bumps[0].old_price * 100).toFixed(1) : '0';
  
  var html = '';
  
  html += '<div style="margin-bottom:1rem;padding:1rem;background:#f8faff;border-radius:10px;border:1px solid var(--border)">';
  html += '<div style="font-size:0.78rem;color:var(--muted);margin-bottom:4px">Scenario: Drop exams by $' + dropAmt + '</div>';
  html += '<div style="display:flex;gap:1.5rem;flex-wrap:wrap">';
  html += '<div><span style="font-size:0.68rem;color:var(--muted)">Revenue Lost</span><br><span style="font-size:1.1rem;font-weight:800;color:var(--red)">-$' + totalLoss.toLocaleString('en-US', {maximumFractionDigits:0}) + '</span></div>';
  html += '<div><span style="font-size:0.68rem;color:var(--muted)">Revenue Recovered</span><br><span style="font-size:1.1rem;font-weight:800;color:var(--green)">+$' + totalGain.toLocaleString('en-US', {maximumFractionDigits:0}) + '</span></div>';
  html += '<div><span style="font-size:0.68rem;color:var(--muted)">Net</span><br><span style="font-size:1.1rem;font-weight:800;color:' + (net>=0?'var(--green)':'var(--red)') + '">' + (net>=0?'+':'') + '$' + net.toLocaleString('en-US', {maximumFractionDigits:0}) + '</span></div>';
  html += '<div><span style="font-size:0.68rem;color:var(--muted)">Uniform Bump</span><br><span style="font-size:1.1rem;font-weight:800;color:var(--primary)">+' + bumpPct + '%</span></div>';
  html += '</div></div>';
  
  // Exam drop
  if (drops.length) {
    html += '<div style="margin-bottom:1rem"><div style="font-size:0.82rem;font-weight:700;color:var(--red);margin-bottom:8px">📉 Exam Price Drop</div>';
    html += '<table style="width:100%;font-size:0.78rem;border-collapse:collapse">';
    html += '<tr style="color:var(--muted);font-size:0.68rem;border-bottom:1px solid var(--border)"><th style="text-align:left;padding:4px 8px">Service</th><th style="text-align:right;padding:4px 8px">Current</th><th style="text-align:right;padding:4px 8px">New</th><th style="text-align:right;padding:4px 8px">Vol/yr</th><th style="text-align:right;padding:4px 8px">Lost/yr</th></tr>';
    for (var d of drops) {
      html += '<tr style="border-bottom:1px solid #f1f5f9"><td style="padding:6px 8px;font-weight:600">' + escHtml(d.treatment_name || d.treatment_code) + '</td>';
      html += '<td style="text-align:right;padding:6px 8px">$' + d.old_price.toFixed(2) + '</td>';
      html += '<td style="text-align:right;padding:6px 8px;color:var(--red);font-weight:700">$' + d.suggested_price.toFixed(2) + '</td>';
      html += '<td style="text-align:right;padding:6px 8px">' + d.annual_volume + '</td>';
      html += '<td style="text-align:right;padding:6px 8px;color:var(--red);font-weight:700">-$' + Math.abs(d.potential_uplift).toLocaleString('en-US', {maximumFractionDigits:0}) + '</td></tr>';
    }
    html += '</table></div>';
  }
  
  // Top 50 revenue generators bump
  if (bumps.length) {
    html += '<div style="margin-bottom:1rem"><div style="font-size:0.82rem;font-weight:700;color:var(--green);margin-bottom:8px">📈 Top Revenue Services — Uniform +' + bumpPct + '% Bump</div>';
    html += '<div style="font-size:0.72rem;color:var(--muted);margin-bottom:8px">' + bumps.length + ' highest-revenue services each get a +' + bumpPct + '% price increase. Higher volume services recover more in total.</div>';
    html += '<table style="width:100%;font-size:0.78rem;border-collapse:collapse">';
    html += '<tr style="color:var(--muted);font-size:0.68rem;border-bottom:1px solid var(--border)"><th style="text-align:left;padding:4px 8px">Service</th><th style="text-align:right;padding:4px 8px">Current</th><th style="text-align:right;padding:4px 8px">New</th><th style="text-align:right;padding:4px 8px">Bump</th><th style="text-align:right;padding:4px 8px">Vol/yr</th><th style="text-align:right;padding:4px 8px">Gain/yr</th></tr>';
    for (var b of bumps.slice(0, 20)) {
      var bpct = ((b.suggested_price - b.old_price) / b.old_price * 100).toFixed(1);
      html += '<tr style="border-bottom:1px solid #f1f5f9"><td style="padding:6px 8px;font-weight:600">' + escHtml(b.treatment_name || b.treatment_code) + '</td>';
      html += '<td style="text-align:right;padding:6px 8px">$' + b.old_price.toFixed(2) + '</td>';
      html += '<td style="text-align:right;padding:6px 8px;color:var(--green);font-weight:700">$' + b.suggested_price.toFixed(2) + '</td>';
      html += '<td style="text-align:right;padding:6px 8px;color:var(--green);font-weight:700">+' + bpct + '%</td>';
      html += '<td style="text-align:right;padding:6px 8px">' + b.annual_volume + '</td>';
      html += '<td style="text-align:right;padding:6px 8px;color:var(--green);font-weight:700">+$' + b.potential_uplift.toLocaleString('en-US', {maximumFractionDigits:0}) + '</td></tr>';
    }
    html += '</table>';
    if (bumps.length > 20) {
      html += '<div style="font-size:0.72rem;color:var(--muted);margin-top:6px">+ ' + (bumps.length - 20) + ' more items with the same bump</div>';
    }
    html += '</div>';
  }
  
  // Break-even verdict
  html += '<div style="padding:1rem;background:' + (net>=0?'#dcfce7':'#fef2f2') + ';border-radius:10px;text-align:center">';
  html += '<div style="font-size:0.9rem;font-weight:800;color:' + (net>=0?'#16a34a':'#dc2626') + '">' + (net>=0 ? '✅ This plan recovers the gap' : '⚠️ Still short — need more bump or fewer drops') + '</div>';
  html += '<div style="font-size:0.75rem;color:var(--muted);margin-top:4px">Net impact: ' + (net>=0?'+':'') + '$' + net.toLocaleString('en-US', {maximumFractionDigits:0}) + '/year</div>';
  html += '</div>';
  
  // Implement button
  html += '<div style="margin-top:1rem;text-align:center;padding-bottom:0.5rem">';
  html += '<button onclick="activateShoppables()" style="background:var(--primary);color:#fff;border:none;padding:10px 28px;border-radius:10px;font-size:0.9rem;font-weight:700;cursor:pointer">Implement Campaign</button>';
  html += '</div>';
  
  document.getElementById('c4PlanContent').innerHTML = html;
  document.getElementById('c4PlanModal').style.display = 'block';
};

// Activate shoppables campaign
window.activateShoppables = async function() {
  const btn = document.getElementById('c4ActivateBtn');
  const items = c4ProjectedItems.length ? c4ProjectedItems : window.c4Items;
  if (!items.length) { alert('No items to activate'); return; }
  btn.disabled = true;
  btn.textContent = 'Activating...';
  try {
    const res = await fetch(SB_URL + '/rest/v1/campaigns', {
      method: 'POST',
      headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, 'Content-Type': 'application/json', Prefer: 'return=representation' },
      body: JSON.stringify({
        clinic_id: 'rosslyn', campaign_type: 'shoppables',
        name: 'Shoppables — Exam Drop Initiative', status: 'active',
        activated_at: new Date().toISOString(),
        total_items: items.length, implemented_items: 0,
        total_potential: items.reduce((s, i) => s + Math.max(0, i.potential_uplift), 0),
        total_captured: 0
      })
    });
    const [camp] = await res.json();
    if (!camp) throw new Error('Failed to create campaign');
    const campaignItems = items.map(item => ({
      clinic_id: 'rosslyn',
      campaign_id: camp.id,
      service_code: item.treatment_code || item.service_code,
      service_name: item.treatment_name || item.service_name,
      old_price: item.old_price,
      suggested_price: item.suggested_price,
      price_increase_pct: item.old_price > 0 ? ((item.suggested_price - item.old_price) / item.old_price * 100) : 0,
      expected_monthly_uplift: (item.potential_uplift || 0) / 12,
      expected_annual_uplift: item.potential_uplift || 0,
      volume_risk: 'low',
      status: 'pending',
      priority: 1
    }));
    await fetch(SB_URL + '/rest/v1/std_approval_queue', {
      method: 'POST',
      headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, 'Content-Type': 'application/json', Prefer: 'return=minimal' },
      body: JSON.stringify(campaignItems)
    });
    location.reload();
  } catch (e) {
    alert('Activation failed: ' + e.message);
    btn.disabled = false;
    btn.textContent = 'Start Campaign';
  }
};

function weeksAgo(n) {
  const d = new Date();
  d.setDate(d.getDate() - n * 7);
  return d.toISOString().split('T')[0];
}

function drawExamChart(rollingData, launchDate) {
  const canvas = document.getElementById('c4ExamChart');
  if (!canvas) return;
  if (c4ExamChartInstance) c4ExamChartInstance.destroy();
  if (!rollingData || !rollingData.length) return;

  const labels = rollingData.map(r => {
    const d = new Date(r.week);
    return (d.getMonth() + 1) + '/' + d.getDate();
  });
  const counts = rollingData.map(r => r.count);
  const avgs = rollingData.map(r => r.avg);

  // Find launch week index for annotation
  const launchIdx = rollingData.findIndex(r => r.week >= launchDate);

  const datasets = [
    {
      label: 'Weekly Exams',
      data: counts,
      backgroundColor: '#f59e0b30',
      borderColor: '#f59e0b',
      borderWidth: 1,
      type: 'bar',
      barThickness: 6,
      order: 2
    },
    {
      label: '4-Week Avg',
      data: avgs,
      borderColor: '#2563eb',
      borderWidth: 2.5,
      pointRadius: 0,
      tension: 0.3,
      fill: false,
      order: 1
    }
  ];

  // Add launch line as annotation via a vertical line dataset
  if (launchIdx >= 0) {
    datasets.push({
      label: 'Launch',
      data: labels.map((_, i) => i === launchIdx ? Math.max(...counts) : null),
      borderColor: '#ef4444',
      borderWidth: 2,
      borderDash: [4, 4],
      pointRadius: 6,
      pointStyle: 'line',
      pointBorderColor: '#ef4444',
      pointBackgroundColor: '#ef4444',
      showLine: false,
      order: 0
    });
  }

  c4ExamChartInstance = new Chart(canvas, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            title: ctx => ctx[0].label,
            label: ctx => ctx.dataset.label + ': ' + (ctx.parsed.y != null ? ctx.parsed.y : '')
          }
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 9 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 12 } },
        y: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 9 } }, beginAtZero: true }
      }
    }
  });
}

function renderC4Table(items, filter) {
  let filtered = items;
  if (filter === 'drops') filtered = items.filter(i => i.potential_uplift < 0);
  if (filter === 'bumps') filtered = items.filter(i => i.potential_uplift >= 0);

  document.getElementById('c4Table').innerHTML = filtered.map(it => {
    const isDrop = it.potential_uplift < 0;
    const delta = it.suggested_price - it.old_price;
    const typeLabel = isDrop ? '<span style="color:var(--red);font-weight:600">▼ Drop</span>' : '<span style="color:var(--green);font-weight:600">▲ Bump</span>';
    return `<tr style="${isDrop?'background:#fff7ed':''}">
      <td><b>${escHtml(it.treatment_code)}</b></td>
      <td>${escHtml((itemNamesMap && itemNamesMap[it.treatment_code]) || it.treatment_name || '')}</td>
      <td class="num">${typeLabel}</td>
      <td class="num">$${it.old_price.toFixed(2)}</td>
      <td class="num" style="color:${isDrop?'var(--red)':'var(--green)'};font-weight:700">$${it.suggested_price.toFixed(2)}</td>
      <td class="num" style="color:${isDrop?'var(--red)':'var(--green)'}">${isDrop?'':'+'}$${delta.toFixed(2)}</td>
      <td class="num">${it.annual_volume}</td>
      <td class="num" style="font-weight:700;color:${isDrop?'var(--red)':'var(--green)'}">${isDrop?'-':'+'}$${Math.abs(it.potential_uplift).toFixed(0)}</td>
    </tr>`;
  }).join('');
}

window.c4Filter = function(btn, filter) {
  btn.parentElement.querySelectorAll('.c1-filter').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderC4Table(window.c4Items, filter);
};

function escHtml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// Load campaign state on init
document.addEventListener('DOMContentLoaded', () => {
  setTimeout(() => { CampaignUI.loadCampaignState(); loadExamPairings().then(() => loadShoppables()); }, 1000);
});


// ===== REVENUE CALENDAR (clean rewrite) =====
// Revenue from daily_kpis, COGS from services + items
var CAL_YEAR = new Date().getFullYear();
var CAL_MONTH = new Date().getMonth();
var calCostsCache = null;
var calDayModal = null;

async function calGetCosts(){
  if(calCostsCache) return calCostsCache;
  // std_services has no unit_cost column; return empty costs cache
  calCostsCache = {};
  return calCostsCache;
}

function calFmt(n){return n>=1000?"$"+(n/1000).toFixed(1)+"k":"$"+n.toFixed(0);}
function calFmtFull(n){return "$"+n.toLocaleString("en-CA",{minimumFractionDigits:2,maximumFractionDigits:2});}

// Fetch month: revenue from daily_kpis, COGS from services
async function calFetchMonth(y,m){
  var s=y+"-"+String(m+1).padStart(2,"0")+"-01";
  var eDt=new Date(y,m+1,1);
  var e=eDt.getFullYear()+"-"+String(eDt.getMonth()+1).padStart(2,"0")+"-01";

  // 1. Revenue from daily_kpis (pre-computed, accurate)
  var kpiMap={};
  var kr=await fetch(SB_URL+"/rest/v1/daily_kpis?select=txn_day,revenue,visits,line_items,unique_services,avg_line_amount&txn_day=gte."+s+"&txn_day=lt."+e+"&limit=1000",{headers:{"apikey":SB_KEY,"Authorization":"Bearer "+SB_KEY}});
  var kpis=await kr.json();
  kpis.forEach(function(k){
    var day=k.txn_day;
    if(day) kpiMap[day.slice(0,10)]={rev:k.revenue||0,visits:k.visits||0,line_items:k.line_items||0,unique_services:k.unique_services||0,avg_line:k.avg_line_amount||0};
  });

  // 2. COGS from daily_cogs (precomputed)
  var cogsMap={};
  var cr=await fetch(SB_URL+"/rest/v1/daily_cogs?select=day,cogs&day=gte."+s+"&day=lt."+e+"&limit=1000",{headers:{"apikey":SB_KEY,"Authorization":"Bearer "+SB_KEY}});
  if(cr.ok){
    var cogsRows=await cr.json();
    cogsRows.forEach(function(r){
      if(r.day) cogsMap[String(r.day).slice(0,10)] = r.cogs||0;
    });
  }

  // 3. Staff costs from daily_staff_cost
  var staffMap={};
  var sr=await fetch(SB_URL+"/rest/v1/daily_staff_cost?select=day,staff_cost,staff_hours,staff_count,shifts&day=gte."+s+"&day=lt."+e+"&limit=1000",{headers:{"apikey":SB_KEY,"Authorization":"Bearer "+SB_KEY}});
  if(sr.ok){
    var staffRows=await sr.json();
    staffRows.forEach(function(r){
      if(r.day) staffMap[String(r.day).slice(0,10)]={cost:r.staff_cost||0,hours:r.staff_hours||0,count:r.staff_count||0,shifts:r.shifts||0};
    });
  }

  // 4. Merge
  var byDay={};
  var allDays=new Set(Object.keys(kpiMap).concat(Object.keys(cogsMap)).concat(Object.keys(staffMap)));
  allDays.forEach(function(day){
    var k=kpiMap[day];
    var st=staffMap[day];
    byDay[day]={rev:k?k.rev:0,cogs:(cogsMap[day]===undefined?null:cogsMap[day]),staff_cost:st?st.cost:0,staff_hours:st?st.hours:0,staff_count:st?st.count:0,shifts:st?st.shifts:0,visits:k?k.visits:0,line_items:k?k.line_items:0,unique_services:k?k.unique_services:0,avg_line:k?k.avg_line:0};
  });
  return byDay;
}

// Fetch single day detail
async function calFetchDay(day){
  // Revenue & stats from daily_kpis
  var kr=await fetch(SB_URL+"/rest/v1/daily_kpis?select=txn_day,revenue,visits,line_items,unique_services,avg_line_amount&txn_day=eq."+day,{headers:{"apikey":SB_KEY,"Authorization":"Bearer "+SB_KEY}});
  var kpis=await kr.json();
  var kpi=kpis.length?kpis[0]:{revenue:0,visits:0,line_items:0,unique_services:0,avg_line_amount:0};
  var rev=kpi.revenue||0;

  // COGS from daily_cogs
  var cr=await fetch(SB_URL+"/rest/v1/daily_cogs?select=day,cogs&day=eq."+day,{headers:{"apikey":SB_KEY,"Authorization":"Bearer "+SB_KEY}});
  var crows=cr.ok?await cr.json():[];
  var cogs=crows.length? (crows[0].cogs||0) : 0;

  // Staff cost from daily_staff_cost
  var str=await fetch(SB_URL+"/rest/v1/daily_staff_cost?select=day,staff_cost,staff_hours,staff_count,shifts&day=eq."+day,{headers:{"apikey":SB_KEY,"Authorization":"Bearer "+SB_KEY}});
  var strows=str.ok?await str.json():[];
  var st=strows.length?strows[0]:{staff_cost:0,staff_hours:0,staff_count:0,shifts:0};

  return {rev:rev,cogs:cogs,staff_cost:st.staff_cost||0,staff_hours:st.staff_hours||0,staff_count:st.staff_count||0,shifts:st.shifts||0,items:{},txns:kpi.line_items||0,visits:kpi.visits||0,line_items:kpi.line_items||0,unique_services:kpi.unique_services||0,avg_line:kpi.avg_line_amount||0};
}


async function calLoad(){
  document.getElementById("calLoading").style.display="block";
  document.getElementById("calDays").innerHTML="";
  document.getElementById("calSummary").innerHTML="";
  var MN=["January","February","March","April","May","June","July","August","September","October","November","December"];
  document.getElementById("calMonthLabel").textContent=MN[CAL_MONTH]+" "+CAL_YEAR;

  var byDay=await calFetchMonth(CAL_YEAR,CAL_MONTH);
  document.getElementById("calLoading").style.display="none";

  var container=document.getElementById("calDays");
  var firstDay=new Date(CAL_YEAR,CAL_MONTH,1).getDay();
  var lastDay=new Date(CAL_YEAR,CAL_MONTH+1,0).getDate();
  var totalRev=0,totalCogs=0;

  for(var i=0;i<firstDay;i++){
    var em=document.createElement("div");
    em.style.cssText="min-height:85px;border-right:1px solid #dbeafe;border-bottom:1px solid #dbeafe;background:#fafbff;";
    container.appendChild(em);
  }

  for(var d=1;d<=lastDay;d++){
    var ds=CAL_YEAR+"-"+String(CAL_MONTH+1).padStart(2,"0")+"-"+String(d).padStart(2,"0");
    var dd=byDay[ds];
    var cell=document.createElement("div");
    cell.setAttribute('data-day', ds);
    var col=(firstDay+d-1)%7;
    var br=col<6?"1px solid #dbeafe":"none";

    if(!dd||dd.rev===0){
      cell.style.cssText="padding:0.4rem 0.5rem;min-height:85px;border-right:"+br+";border-bottom:1px solid #dbeafe;background:#f8fafc;";
      cell.innerHTML="<div style='font-size:0.72rem;font-weight:700;color:#94a3b8'>"+d+"</div><div style='font-size:0.65rem;color:#cbd5e1;margin-top:4px'>Closed</div>";
    } else {
      var rev=dd.rev,cogs=dd.cogs,staffCost=dd.staff_cost||0;
      var gp=(cogs==null?0:(rev-cogs));
      var trueProfit=rev-(cogs||0)-staffCost;
      var margin=(cogs==null?0:(rev>0?gp/rev*100:0));
      var trueMargin=rev>0?trueProfit/rev*100:0;
      var cogsP=(cogs==null?0:(rev>0?cogs/rev*100:0));
      totalRev+=rev; if(cogs!=null) totalCogs+=cogs;
      var bg,bc;
      if(cogs==null){bg="#eef2ff";bc="#6366f1";}
      else if(trueMargin>=50){bg="#dcfce7";bc="#16a34a";}
      else if(trueMargin>=30){bg="#fef9c3";bc="#ca8a04";}
      else{bg="#fee2e2";bc="#ef4444";}
      cell.style.cssText="padding:0.4rem 0.5rem;min-height:85px;border-right:"+br+";border-bottom:1px solid #dbeafe;background:"+bg+";border-left:3px solid "+bc+";cursor:pointer;";
      cell.innerHTML="<div style='font-size:0.72rem;font-weight:700;color:#1e3a5f'>"+d+"</div>"
        +"<div style='font-size:0.8rem;font-weight:700;color:#1e3a5f'>"+calFmt(rev)+"</div>"
        +"<div style='font-size:0.64rem;color:#64748b'>COGS "+(cogs==null?"—":calFmt(cogs))+(staffCost>0?" | Labor "+calFmt(staffCost):"")+"</div>"
        +"<div style='font-size:0.64rem;font-weight:600;color:"+bc+"'>"+(cogs==null?"":"Net "+(trueMargin).toFixed(1)+"%")+"</div>";
      (function(dayStr){cell.onclick=function(){openDayModal(dayStr);};})(ds);
    }
    container.appendChild(cell);
  }

  var total=firstDay+lastDay,rem=total%7;
  if(rem>0){for(var i=rem;i<7;i++){var em=document.createElement("div");em.style.cssText="min-height:85px;border-bottom:1px solid #dbeafe;background:#fafbff;";container.appendChild(em);}}

  var avgM=(totalRev>0 && totalCogs>0)?(totalRev-totalCogs)/totalRev*100:null;
  var totalStaffCost=Object.values(byDay).reduce(function(a,b){return a+(b.staff_cost||0);},0);
  var totalNetProfit=totalRev-(totalCogs||0)-totalStaffCost;
  var sumEl=document.getElementById("calSummary");
  function kpi(l,v,c){return "<div style='display:flex;flex-direction:column;gap:2px'><div style='font-size:0.68rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em'>"+l+"</div><div style='font-size:1rem;font-weight:700;color:"+(c||"var(--text)")+"'>"+v+"</div></div>";}
  var monthlyFixed=0; if(window.clinicTotalFixed) monthlyFixed=window.clinicTotalFixed();
  var daysInMonth=new Date(CAL_YEAR, CAL_MONTH+1, 0).getDate();
  var dailyFixed=monthlyFixed/daysInMonth;
  sumEl.innerHTML=kpi("Month Revenue",calFmtFull(totalRev))
    +kpi("Total COGS",(totalCogs>0?calFmtFull(totalCogs):"—"),"#ef4444")
    +kpi("Total Labor",(totalStaffCost>0?calFmtFull(totalStaffCost):"—"),"#2563eb")
    +kpi("Net Profit",(totalNetProfit>0?calFmtFull(totalNetProfit):"—"),"#16a34a")
    +kpi("Net Margin (%)",(totalRev>0?(totalNetProfit/totalRev*100).toFixed(1)+"%":"—"),"#16a34a")
}

async function openDayModal(day){
  var MN=["January","February","March","April","May","June","July","August","September","October","November","December"];
  if(!calDayModal){
    calDayModal=document.createElement("div");
    calDayModal.className="modal-overlay";
    calDayModal.onclick=function(e){if(e.target===calDayModal){calDayModal.classList.remove('open');calDayModal.style.display="none";}};
    calDayModal.innerHTML='<div class="modal-content" style="max-width:92vw;height:88vh;overflow:hidden"><div class="modal-header"><h2 id="calDayTitle"></h2><button class="modal-close" onclick="calDayModal.classList.remove(\'open\');calDayModal.style.display=\'none\'">&times;</button></div><div class="modal-body" id="calDayBody" style="height:calc(88vh - 64px);overflow:auto"></div></div>';
    document.body.appendChild(calDayModal);
  }
  var d=new Date(day+"T12:00:00");
  document.getElementById("calDayTitle").textContent=MN[d.getMonth()]+" "+d.getDate()+", "+d.getFullYear();
  document.getElementById("calDayBody").innerHTML="<div style='text-align:center;padding:2rem;color:var(--muted)'>Loading...</div>";
  calDayModal.style.display="flex";
  calDayModal.classList.add('open');

  var data;
  try {
    data=await calFetchDay(day);
  } catch(e){
    logCalError('Failed to load day '+day, e);
    document.getElementById('calDayBody').innerHTML='<div style="color:#ef4444;padding:1rem">Error loading day. See console.</div>';
    return;
  }
  var rev=data.rev,cogs=data.cogs,gp=rev-cogs,margin=rev>0?gp/rev*100:0;
  var staffCost=data.staff_cost||0;
  var staffHours=data.staff_hours||0;
  var monthlyFixed=0;
  if(window.clinicTotalFixed) monthlyFixed=window.clinicTotalFixed();
  var daysInMonth=new Date(d.getFullYear(), d.getMonth()+1, 0).getDate();
  var dailyFixed=monthlyFixed/daysInMonth;
  var netProfit=gp-dailyFixed-staffCost;
  var avgTxn=data.visits>0?rev/data.visits:0;
  var sorted=Object.values(data.items).sort(function(a,b){return b.rev-a.rev;});

  var h='<div style="max-width:1100px;margin:0 auto">';
  h+='<div style="font-size:0.85rem;color:#64748b;margin-bottom:0.75rem">Daily Analytics</div>';
  h+='<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.8rem;margin-bottom:1.2rem">';
  function kpi(l,v,c){return '<div style="background:#f8fafc;border-radius:10px;padding:0.7rem 0.9rem"><div style="font-size:0.66rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.05em">'+l+'</div><div style="font-size:1.15rem;font-weight:800;color:'+(c||"#1e3a5f")+'">'+v+'</div></div>';}
  h+=kpi("Revenue",calFmtFull(rev),"#1e3a5f");
  h+=kpi("COGS",calFmtFull(cogs),"#ef4444");
  h+=kpi("Gross Profit",calFmtFull(gp),"#16a34a");
  h+=kpi("Gross Profit (%)",margin.toFixed(1)+"%",margin>=85?"#16a34a":margin>=70?"#ca8a04":"#ef4444");
  var trueProfit=rev-cogs-staffCost;
  h+=kpi("Fixed Cost",calFmtFull(dailyFixed),"#8b5cf6");
  h+=kpi("Staff Cost",staffCost>0?calFmtFull(staffCost):"\u2014","#2563eb");
  h+=kpi("Staff Hours",staffHours>0?staffHours.toFixed(1)+"h":"\u2014","#2563eb");
  h+=kpi("Net Profit (after labor)",calFmtFull(trueProfit),trueProfit>=0?"#16a34a":"#ef4444");
  h+=kpi("Avg per Visit",calFmtFull(avgTxn),"#0ea5e9");
  h+=kpi("Visits",""+data.visits,"#1e3a5f");
  h+=kpi("Unique Services",""+data.unique_services,"#1e3a5f");
  h+='</div>';
  // Service breakdown omitted for fast view
  h+='</div>';
  document.getElementById("calDayBody").innerHTML=h;
}


// Calendar click delegation (robust)
var calDaysClickBound=false;
document.addEventListener('DOMContentLoaded', function(){
  if(calDaysClickBound) return;
  var container=document.getElementById('calDays');
  if(container){
    container.addEventListener('click', function(e){
      var cell=e.target.closest('[data-day]');
      if(cell && cell.getAttribute('data-day')){
        openDayModal(cell.getAttribute('data-day'));
      } else {
        logCalError('Clicked calendar but no data-day attr');
      }
    });
    calDaysClickBound=true;
  }
});
function calPrev(){CAL_MONTH--;if(CAL_MONTH<0){CAL_MONTH=11;CAL_YEAR--;}calLoad();}
function calNext(){CAL_MONTH++;if(CAL_MONTH>11){CAL_MONTH=0;CAL_YEAR++;}calLoad();}

document.addEventListener('DOMContentLoaded', function(){ if(document.getElementById('tab-insights')?.classList.contains('active')) calLoad(); });

function logCalError(msg, err){
  console.error('[Calendar]', msg, err||'');
  var log = document.getElementById('calErrorLog');
  if(log){
    var t = new Date().toLocaleTimeString();
    log.innerHTML = '<div style="color:#ef4444">['+t+'] '+msg+'</div>' + (err?('<div style="font-size:0.8rem;color:#64748b">'+String(err)+'</div>'):'') + log.innerHTML;
  }
}
window.addEventListener("load",function(){
  var _st=window.showTab;
  window.showTab=function(tab,btn){
    _st(tab,btn);
    if(tab==="insights") { calLoad(); if (typeof InsightsDashboard!=='undefined') InsightsDashboard.init(); }
    if(tab==="analytics") { if (typeof WidgetBoard!=='undefined') WidgetBoard.init(); }
  };
  // If insights tab is already active on load
  if(document.getElementById('tab-insights')?.classList.contains('active')) calLoad();
});
</script>

